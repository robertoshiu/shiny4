---
import PageLayout from '../layouts/PageLayout.astro';
import SubHero from '../components/SubHero.astro';
import { getCollection } from 'astro:content';
import { t, localized, siblingUrl } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

interface Props {
  locale?: Locale;
}
const { locale = 'zh-Hant' } = Astro.props;

/* ── Data: L1–L6 sorted by order ──────────────────────────────────────────── */
const allLayers = await getCollection('layers');
const layers = allLayers.sort((a, b) => a.data.order - b.data.order);

/* ── Accent mapping: L1–L4 = sla (gold), L5 = gov (sage), L6 = dr (clay) ── */
function chapterAccent(i: number): 'sla' | 'gov' | 'dr' {
  if (i <= 3) return 'sla';
  if (i === 4) return 'gov';
  return 'dr';
}
---

<PageLayout
  title={t('page.experience.title', locale)}
  description={t('experience.metaDescription', locale)}
  locale={locale}
>
  <!-- Hero slot: SubHero with eyebrow / title / scroll-hint / lead -->
  <Fragment slot="hero">
    <SubHero
      locale={locale}
      eyebrow={t('experience.eyebrow', locale)}
      zhTitle={t('experience.title', locale)}
      enLabel={t('experience.scrollHint', locale)}
      lede={t('experience.lead', locale)}
    />
  </Fragment>

  <!-- ── Walkthrough: L1–L6 chapters ──────────────────────────────────────── -->
  <!--
    DOM contract for Stage 4b:
      [data-experience]     — root hook for the scroll engine
      [data-chapter="i"]    — per-chapter hook (0-indexed)
      chapter--{accent}     — accent class sets --energy; Stage 4b reads it
  -->
  <section class="experience" data-experience aria-label={t('experience.title', locale)}>
    <!-- Stage 4b: fixed canvas backdrop — aria-hidden, z-index:-1, behind transparent chapters -->
    <canvas id="experience-canvas" class="experience__canvas" aria-hidden="true" tabindex="-1"></canvas>
    <ol class="experience__chapters">
      {layers.map((layer, i) => {
        const accent = chapterAccent(i);
        return (
          <li
            class={`experience__chapter chapter--${accent}`}
            data-chapter={i}
          >
            {/* Ghost numeral — aria-hidden; visual beat only */}
            <span class="experience__num" aria-hidden="true">{layer.data.num}</span>

            <div class="experience__body">
              <h2 class="experience__name">
                {localized(layer.data, 'zhName', locale) as string}
              </h2>
              <p class="experience__en">
                {localized(layer.data, 'enLabel', locale) as string}
              </p>
              <p class="experience__scope">
                {localized(layer.data, 'scope', locale) as string}
              </p>
            </div>
          </li>
        );
      })}
    </ol>
  </section>

  <!-- ── Closing CTA ──────────────────────────────────────────────────────── -->
  <section class="experience-cta" aria-labelledby="experience-cta-heading">
    <p id="experience-cta-heading" class="experience-cta__line">
      {t('experience.ctaLine', locale)}
    </p>
    <a
      class="experience-cta__btn"
      href={siblingUrl('/solutions/', locale)}
    >
      {t('experience.cta', locale)}
    </a>
  </section>
</PageLayout>

<!-- ── Stage 4b: scroll-driven cleanroom fly-through engine ──────────────── -->
<!--
  Lifecycle mirrors HeroCanvas.astro exactly:
    astro:page-load  → mount()  (lazy via requestIdleCallback / setTimeout fallback)
    astro:before-swap → teardown()  (View-Transition safety)
    pagehide         → teardown()  (real page exit)

  Gates:
    prefersReducedMotion() → no-op; canvas stays opacity:0; all chapters opaque (CSS).
    max-width: 48rem       → no-op; mobile gets static walkthrough; all chapters opaque (CSS).
    canvas not in DOM      → no-op (not on this page).
    handle already set     → no-op (already mounted).
-->
<script>
  import { initCleanroomFly } from '../scripts/motion/cleanroom-fly';
  import { prefersReducedMotion } from '../scripts/theme-motion';
  import { getLenis } from '../scripts/motion/smooth-scroll';

  let handle: { destroy(): void; setScroll(p: number): void } | null = null;
  let scrollUnsubscribe: (() => void) | null = null;
  let sectionIO: IntersectionObserver | null = null;
  let chapterIO: IntersectionObserver | null = null;

  /** Compute scroll progress over the [data-experience] section and push to engine. */
  function updateProgress(): void {
    const sec = document.querySelector<HTMLElement>('[data-experience]');
    if (!sec || !handle) return;
    const rect  = sec.getBoundingClientRect();
    const total = rect.height - window.innerHeight;
    const p     = Math.max(0, Math.min(1, -rect.top / Math.max(total, 1)));
    handle.setScroll(p);
  }

  function mount(): void {
    // Accessible path: canvas stays opacity:0; chapters remain fully opaque via CSS.
    if (prefersReducedMotion()) return;
    // Mobile path: static walkthrough; chapters fully opaque via CSS.
    if (window.matchMedia('(max-width: 48rem)').matches) return;

    const canvas = document.getElementById('experience-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;   // not on this page
    if (handle) return;    // already mounted

    const start = (): void => {
      if (handle) return;
      if (!canvas.isConnected) return; // navigated away before idle fired

      // Init engine (engine also self-gates DPR / save-data / visibility)
      handle = initCleanroomFly(canvas);

      // ── Scroll driver ──────────────────────────────────────────────────────
      // Prefer Lenis (initialized by BaseLayout); fall back to native scroll.
      const lenis = getLenis();
      if (lenis) {
        lenis.on('scroll', updateProgress);
        // Use getLenis()?.off at teardown time so it's safe after lenis.destroy().
        scrollUnsubscribe = () => getLenis()?.off('scroll', updateProgress);
      } else {
        window.addEventListener('scroll', updateProgress, { passive: true });
        scrollUnsubscribe = () => window.removeEventListener('scroll', updateProgress);
      }

      // ── Section activation IO ──────────────────────────────────────────────
      // Canvas fades in when the experience section enters the viewport,
      // fades out when it exits (past the CTA / into the footer).
      const sec = document.querySelector('[data-experience]');
      if (sec) {
        sectionIO = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              canvas.classList.toggle('is-active', entry.isIntersecting);
            }
          },
          { threshold: 0 },
        );
        sectionIO.observe(sec);
      }

      // ── Chapter focus IO ───────────────────────────────────────────────────
      // Dims chapters at 0.6 opacity; adds .is-active (opacity:1) to whichever
      // chapter is currently centred in the viewport (rootMargin ±45% = centre 10%).
      const chapters = document.querySelectorAll('[data-chapter]');
      chapterIO = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            entry.target.classList.toggle('is-active', entry.isIntersecting);
          }
        },
        { rootMargin: '-45% 0px -45% 0px', threshold: 0 },
      );
      for (const ch of chapters) chapterIO.observe(ch);

      // Seed initial scroll progress so the fly position is correct on first paint.
      requestAnimationFrame(() => updateProgress());
    };

    // Lazy start via requestIdleCallback (timeout 1800ms; setTimeout 160ms fallback).
    if ('requestIdleCallback' in window) {
      (window as unknown as { requestIdleCallback: (cb: () => void, o?: object) => void })
        .requestIdleCallback(start, { timeout: 1800 });
    } else {
      setTimeout(start, 160);
    }
  }

  function teardown(): void {
    handle?.destroy();
    handle = null;
    scrollUnsubscribe?.();
    scrollUnsubscribe = null;
    sectionIO?.disconnect();
    sectionIO = null;
    chapterIO?.disconnect();
    chapterIO = null;
    // Remove activation classes so state is clean for the next mount.
    const canvas = document.getElementById('experience-canvas');
    if (canvas) canvas.classList.remove('is-active');
    document.querySelectorAll('[data-chapter]').forEach((ch) =>
      ch.classList.remove('is-active'),
    );
  }

  // Re-mount on every page-load (initial + View-Transition nav);
  // release engine before each swap and on real page exit.
  document.addEventListener('astro:page-load', mount);
  document.addEventListener('astro:before-swap', teardown);
  window.addEventListener('pagehide', teardown);
</script>

<style>
  /* ── Canvas backdrop (Stage 4b) ──────────────────────────────────────────── */
  /*
    position:fixed keeps the canvas viewport-anchored as you scroll through the
    section. z-index:-1 places it below normal-flow content (chapter text) but
    above the root/body background — so the wireframe shows through the
    transparent section+chapters without covering any readable text.
  */
  .experience__canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
    display: block;
    opacity: 0;
    transition: opacity var(--dur-slow) var(--ease-out);
  }
  .experience__canvas.is-active {
    opacity: 1;
  }

  /* ── Walkthrough section ─────────────────────────────────────────────────── */
  .experience {
    /* transparent so the fixed canvas at z-index:-1 shows through */
    background: transparent;
  }

  .experience__chapters {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Each chapter: a tall deliberate beat — floats on air, no card box */
  .experience__chapter {
    min-height: 70svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: clamp(5rem, 12vw, 9rem) var(--gutter);
    position: relative;
    /* Alternating deep / base ground to lightly differentiate beats */
    background: transparent;
    border-top: 1px solid var(--border);
    /* Stage 4b: dims non-centred chapters; .is-active is added by JS to the
       chapter currently in the centre viewport band.
       Under reduced-motion / mobile this is overridden to 1 (see below). */
    opacity: 0.6;
    transition: opacity var(--dur-base) var(--ease-out);
  }
  .experience__chapter:first-child {
    border-top: none;
  }
  .experience__chapter.is-active {
    opacity: 1;
  }

  /* Thin accent rule — centered, from --energy */
  .experience__chapter::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: clamp(3rem, 8vw, 6rem);
    height: 2px;
    background: var(--energy);
  }
  .experience__chapter:first-child::before {
    /* First chapter has no border-top, so no rule — let the SubHero lead in */
    display: none;
  }

  /* Ghost numeral — giant, faint, accent-coloured ─────────────────────────── */
  .experience__num {
    display: block;
    font-family: var(--font-mono);
    font-size: clamp(5rem, 18vw, 13rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--energy);
    opacity: 0.10;
    user-select: none;
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
    /* Stage 4b hook: will receive translateY from scroll engine */
  }

  /* Body content — layered below the ghost numeral ─────────────────────────── */
  .experience__body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    max-width: 60ch;
  }

  /* Layer name — large display type ──────────────────────────────────────── */
  .experience__name {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 4rem);
    font-weight: 600;
    color: var(--ink);
    line-height: 1.08;
    margin: 0;
    font-variation-settings: 'opsz' 72;
  }

  /* EN / technical label — mono, accent colour, spaced caps ──────────────── */
  .experience__en {
    font-family: var(--font-mono);
    font-size: clamp(0.72rem, 1.4vw, 0.88rem);
    letter-spacing: 0.2em;
    color: var(--energy);
    margin: 0;
    text-transform: uppercase;
  }

  /* Scope description — secondary prose ──────────────────────────────────── */
  .experience__scope {
    font-size: clamp(0.9rem, 1.8vw, 1rem);
    color: var(--ink-muted);
    line-height: 1.7;
    margin: 0;
  }

  /* Hover: faint energy glow on background — calm, no translation ─────────── */
  @media (hover: hover) {
    .experience__chapter {
      /* Include opacity so the chapter dim still animates on hover/desktop. */
      transition:
        background var(--dur-quick) var(--ease-out),
        opacity var(--dur-base) var(--ease-out);
    }
    .experience__chapter:hover {
      background: color-mix(in srgb, var(--energy) 3%, transparent);
    }
  }

  /* ── Closing CTA block ───────────────────────────────────────────────────── */
  .experience-cta {
    max-width: var(--maxw);
    margin-inline: auto;
    padding: clamp(5rem, 12vw, 9rem) var(--gutter);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    text-align: center;
    border-top: 1px solid var(--border);
  }

  .experience-cta__line {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--ink-muted);
    max-width: 52ch;
    line-height: 1.65;
    margin: 0;
  }

  /* CTA button — replicates .cta--clay without importing CTAButton to keep
     the dependency light; same design tokens, same WCAG dark-ink-on-clay rule */
  .experience-cta__btn {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.75rem 1.75rem;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.95rem;
    border-radius: 2px;
    text-decoration: none;
    background: var(--clay);
    color: var(--bg);           /* dark ink on clay — WCAG AA ✓ */
    border: 1px solid var(--clay);
    transition:
      background var(--dur-quick) var(--ease-out),
      border-color var(--dur-quick) var(--ease-out),
      transform var(--dur-quick) var(--ease-out);
  }
  .experience-cta__btn:hover {
    background: var(--clay-deep);
    border-color: var(--clay-deep);
    transform: translateY(-1px);
  }
  /* Sun focus ring: double-ring pattern matching .cta--clay in CTAButton.astro */
  .experience-cta__btn:focus-visible {
    outline: none;
    box-shadow:
      0 0 0 2px var(--bg),
      0 0 0 4px var(--sun);
  }

  /* ── Reduced-motion: strip all transitions; keep chapters fully opaque ────── */
  /* mount() returns early under reduced-motion so .is-active is never added.
     The base opacity:0.6 on .experience__chapter would otherwise dim all chapters,
     so we force opacity:1 here. The canvas stays opacity:0 (no JS activation). */
  @media (prefers-reduced-motion: reduce) {
    .experience__chapter {
      transition: none;
      opacity: 1 !important;
    }
    .experience-cta__btn {
      transition: none;
    }
  }

  /* ── Mobile (≤ 48rem): static walkthrough — chapters fully opaque ─────────── */
  /* mount() returns early on mobile so .is-active is never added; same fix. */
  @media (max-width: 48rem) {
    .experience__chapter {
      opacity: 1;
    }
  }

  /* ── html.reduced-motion class: belt-and-suspenders for JS-driven toggle ──── */
  html.reduced-motion .experience__chapter {
    opacity: 1;
  }
</style>
