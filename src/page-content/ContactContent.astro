---
/**
 * Contact 預約諮詢 — page-content component.
 * Rendered by src/pages/contact.astro (zh-Hant),
 *             src/pages/en/contact.astro (en),
 *             src/pages/zh-hans/contact.astro (zh-Hans).
 */

import PageLayout from '../layouts/PageLayout.astro';
import SubHero from '../components/SubHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import ContactForm from '../components/ContactForm.astro';
import InquiryTypeCard from '../components/InquiryTypeCard.astro';
import CTAButton from '../components/CTAButton.astro';
import HudCoordinate from '../components/HudCoordinate.astro';
import DiagramNetZone from '../components/DiagramNetZone.astro';
import { getCollection } from 'astro:content';
import { t, localized } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const inquiryTypes = (await getCollection('inquiryTypes')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<PageLayout
  title={t('page.contact.title', locale)}
  description={t('page.contact.description', locale)}
  locale={locale}
>
  <!-- ── Hero ─────────────────────────────────────────────────────── -->
  <Fragment slot="hero">
    <SubHero
      eyebrow="09 · ENGAGE"
      zhTitle={t('contact.hero.zhTitle', locale)}
      enLabel="CONTACT // PLAN YOUR INTELLIGENT WAFER FAB"
      lede={t('contact.hero.lede', locale)}
      ctas={[
        { href: '#form',   label: t('contact.hero.cta.form', locale),   variant: 'clay'  },
        { href: '#direct', label: t('contact.hero.cta.direct', locale), variant: 'ghost' },
      ]}
      locale={locale}
    />
  </Fragment>

  <div class="contact-scan-wrapper">

  <!-- ── ENGAGE.00 四步交付流程 ─────────────────────────────────── -->
  <section class="section" id="process" aria-labelledby="heading-00">
    <SectionHeader index="00" zh={t('contact.section00.zh', locale)} en={t('contact.section00.en', locale)} />
    <ProcessSteps locale={locale} />
    <p class="process-note reveal">
      {t('contact.section00.processNote', locale)}
    </p>
  </section>

  <!-- ── NET.01 資安網路拓樸 ────────────────────────────────────── -->
  <section class="section" id="netzone-section" aria-labelledby="heading-netzone">
    <SectionHeader index="02" zh={t('diagram.netzone.section.zh', locale)} en={t('diagram.netzone.section.en', locale)} />
    <DiagramNetZone locale={locale} />
  </section>

  <!-- ── FORM.01 諮詢表單 ────────────────────────────────────────── -->
  <section class="section" id="form" aria-labelledby="heading-01">
    <SectionHeader index="01" zh={t('contact.section01.zh', locale)} en={t('contact.section01.en', locale)} />
    <ContactForm />
  </section>

  <!-- ── DIRECT.02 直接聯絡 ─────────────────────────────────────── -->
  <section class="section section--direct" id="direct" aria-labelledby="heading-02">
    <SectionHeader index="02" zh={t('contact.section02.zh', locale)} en={t('contact.section02.en', locale)} />
    <div class="direct-grid" role="list" aria-label={t('contact.direct.ariaLabel', locale)}>

      <!-- Email (primary) -->
      <div class="direct-card" role="listitem">
        <p class="direct-card__kicker">{t('contact.direct.email.kicker', locale)}</p>
        <a class="direct-card__value direct-card__email" href="mailto:hello@shinylogic.tech">
          hello@shinylogic.tech
        </a>
        <p class="direct-card__sub">{t('contact.direct.email.sub', locale)}</p>
      </div>

      <!-- Response time — sun (service-level / performance) -->
      <div class="direct-card direct-card--sun" role="listitem">
        <p class="direct-card__kicker">{t('contact.direct.response.kicker', locale)}</p>
        <p class="direct-card__value">{t('contact.direct.response.value', locale)}</p>
        <p class="direct-card__sub">{t('contact.direct.response.sub', locale)}</p>
        <span class="accent-tag accent-tag--sun" aria-label={t('contact.direct.response.ariaLabel', locale)}>PERFORMANCE</span>
      </div>

      <!-- Languages — sage (coverage / governance) -->
      <div class="direct-card direct-card--sage" role="listitem">
        <p class="direct-card__kicker">{t('contact.direct.langs.kicker', locale)}</p>
        <p class="direct-card__value">{t('contact.direct.langs.value', locale)}</p>
        <p class="direct-card__sub">{t('contact.direct.langs.sub', locale)}</p>
        <span class="accent-tag accent-tag--sage" aria-label={t('contact.direct.langs.ariaLabel', locale)}>COVERAGE</span>
      </div>

      <!-- Coordinates / location -->
      <div class="direct-card direct-card--coord" role="listitem">
        <p class="direct-card__kicker">{t('contact.direct.coords.kicker', locale)}</p>
        <p class="direct-card__value direct-card__coords">N 24°08′ E 120°41′</p>
        <p class="direct-card__sub">TAIWAN · HSINCHU SCIENCE PARK</p>
        <span class="active-badge">[ ACTIVE ]</span>
      </div>

    </div>
  </section>

  <!-- ── INFO.03 諮詢類型說明 ───────────────────────────────────── -->
  <section class="section" id="inquiry-types" aria-labelledby="heading-03">
    <SectionHeader index="03" zh={t('contact.section03.zh', locale)} en={t('contact.section03.en', locale)} />
    <p class="types-intro reveal">
      {t('contact.section03.intro', locale)}
    </p>
    <div class="inq-grid" role="list" aria-label={t('contact.section03.ariaLabel', locale)}>
      {inquiryTypes.map((type) => (
        <div role="listitem">
          <InquiryTypeCard
            order={type.data.order}
            zhName={String(localized(type.data, 'zhName', locale))}
            enLabel={type.data.enLabel}
            description={String(localized(type.data, 'description', locale))}
            target={String(localized(type.data, 'target', locale))}
            locale={locale}
          />
        </div>
      ))}
    </div>
    <p class="section-hud" aria-hidden="true">
      <HudCoordinate text="X:0903 Y:TYPE · 5 INQUIRY TYPES DEFINED" />
    </p>
  </section>

  <!-- ── CTA 規劃您的智能晶圓廠 ─────────────────────────────────── -->
  <div class="cta-bleed">
    <section class="cta-inner reveal" aria-label={t('contact.cta.ariaLabel', locale)}>
      <p class="cta-eyebrow" aria-hidden="true">ENGAGE</p>
      <h2 class="cta-title">{t('contact.cta.title', locale)}</h2>

      <!-- 3 stat badges — all tri-accents present with labels -->
      <div class="cta-stats" role="list" aria-label={t('contact.cta.statsAriaLabel', locale)}>

        <div class="cta-stat cta-stat--sage" role="listitem">
          <span class="cta-stat__value">{t('contact.cta.sage.value', locale)}</span>
          <span class="cta-stat__label">{t('contact.cta.sage.label', locale)}</span>
          <span class="cta-stat__tag cta-stat__tag--sage" aria-label={t('contact.cta.sage.ariaLabel', locale)}>COVERAGE</span>
        </div>

        <div class="cta-stat cta-stat--clay" role="listitem">
          <span class="cta-stat__value">RTO ≤ <span data-count-up data-to="4">4</span>hr</span>
          <span class="cta-stat__label">{t('contact.cta.clay.label', locale)}</span>
          <span class="cta-stat__tag cta-stat__tag--clay" aria-label={t('contact.cta.clay.ariaLabel', locale)}>RESILIENCE</span>
        </div>

        <div class="cta-stat cta-stat--sun" role="listitem">
          <span class="cta-stat__value">SLO ≥ <span data-count-up data-to="95">95</span>%</span>
          <span class="cta-stat__label">{t('contact.cta.sun.label', locale)}</span>
          <span class="cta-stat__tag cta-stat__tag--sun" aria-label={t('contact.cta.sun.ariaLabel', locale)}>PERFORMANCE</span>
        </div>

      </div>

      <div class="cta-actions">
        <CTAButton variant="clay" href="#form" label={t('contact.cta.submit', locale)} />
        <a class="cta-secondary" href="#process">{t('contact.cta.process', locale)}</a>
      </div>

      <p class="cta-coord" aria-hidden="true">
        <HudCoordinate text="N 24°08′ E 120°41′ · TAIWAN · HSINCHU" />
      </p>
    </section>
  </div>

  </div>{/* end .contact-scan-wrapper */}
</PageLayout>

<script>
  /**
   * ContactContent motion script — full cinematic engine for the Contact page.
   *
   * Boot order (all DOMContentLoaded):
   *  1. bootMotion()        — HUD corner brackets draw-in + nav fade
   *  2. Sub-hero spring     — eyebrow → title (spring) → en-label → lede → CTAs
   *  3. initCursor()        — gold ring HUD cursor with crosshair ticks
   *  4. initSmoothScroll()  — Lenis smooth scroll (no-op under reduced-motion)
   *  5. revealAll(…)        — spring word-stagger on all section-header h2 elements
   *  6. initParallax()      — counter-scroll on ghost section numerals
   *  7. revealOnEnter(…)    — spring reveal for .reveal prose/note blocks
   *  8. bindMagnetic(…)     — magnetic pull on .cta--clay + .cta-secondary
   *  9. initLinkUnderlines()— gold stroke-draw underline on hover/focus for links
   * 10. count-up            — spring overshoot on [data-count-up] numeric spans
   * 11. hero dot-field      — cursor-reactive ember grid behind sub-hero content
   * 12. direct dot-field    — cursor-reactive ember grid behind §02 direct section
   * 13. direct-card stagger — spring stagger cascade on .direct-card entries
   * 14. inq-card stagger    — spring stagger cascade on .inq-grid card entries
   *
   * Reduced-motion: every function is internally gated on prefersReducedMotion().
   * No timelines run; elements are forced to their final states immediately.
   */

  import {
    bootMotion,
    revealOnEnter,
    prefersReducedMotion,
  } from '../scripts/theme-motion';
  import { initCursor } from '../scripts/motion/cursor';
  import { initSmoothScroll } from '../scripts/motion/smooth-scroll';
  import { initParallax } from '../scripts/motion/scroll-fx';
  import { revealAll } from '../scripts/motion/text-reveal';
  import { bindMagnetic, initLinkUnderlines } from '../scripts/motion/magnetic';
  import { mount as mountDotField } from '../scripts/motion/dot-field';
  import { animate, stagger, spring, createTimeline } from 'animejs';

  function init(): void {
    // ── 1. Page-load boot: HUD brackets + nav ────────────────────────────────
    // bootMotion() injects gold SVG corner-bracket decorations, fades the nav,
    // and checks for .hero__* targets — all absent here, so those steps no-op.
    bootMotion();

    // ── 2. Sub-hero spring reveal (boot cascade, offset after HUD draw-in) ────
    // SubHero uses .sub-hero__* classes; bootMotion does not animate them.
    // This mirrors the Home hero cascade timing: eyebrow → title spring →
    // en-label → lede → CTAs, starting 350 ms after DOMContentLoaded.
    if (!prefersReducedMotion()) {
      const subEyebrow = document.querySelector<HTMLElement>('.sub-hero__eyebrow');
      const subTitle   = document.querySelector<HTMLElement>('.sub-hero__title');
      const subEnLabel = document.querySelector<HTMLElement>('.sub-hero__en-label');
      const subLede    = document.querySelector<HTMLElement>('.sub-hero__lede');
      const subCtas    = document.querySelectorAll<HTMLElement>('.sub-hero__ctas > *');

      // Set initial hidden states (mirrors bootMotion pattern for .hero__* elements)
      [subEyebrow, subTitle, subEnLabel, subLede].forEach((el) => {
        if (el) { el.style.opacity = '0'; el.style.transform = 'translateY(28px)'; }
      });
      subCtas.forEach((el) => {
        el.style.opacity  = '0';
        el.style.transform = 'translateY(12px)';
      });

      const tl = createTimeline({ defaults: { ease: 'out(3)' } });

      if (subEyebrow) {
        tl.add(subEyebrow, { opacity: [0, 1], translateY: [12, 0], duration: 400 }, 350);
      }
      if (subTitle) {
        // Spring block reveal matches Home hero title: stiffness:260, damping:22
        tl.add(subTitle, {
          opacity:    [0, 1],
          translateY: [32, 0],
          duration:   540,
          ease:       spring({ stiffness: 260, damping: 22, mass: 0.9 }),
        }, 460);
      }
      if (subEnLabel) {
        tl.add(subEnLabel, { opacity: [0, 1], translateY: [10, 0], duration: 380 }, 620);
      }
      if (subLede) {
        tl.add(subLede, { opacity: [0, 1], duration: 380 }, 700);
      }
      if (subCtas.length) {
        tl.add(subCtas, {
          opacity:    [0, 1],
          translateY: [12, 0],
          delay:      stagger(80),
          duration:   320,
        }, 840);
      }
    }

    // ── 3. Custom HUD cursor (gold ring + crosshair, pointer:fine only) ───────
    initCursor();

    // ── 4. Lenis smooth scroll ────────────────────────────────────────────────
    initSmoothScroll();

    // ── 5. Spring word-stagger on all section-header h2 elements ─────────────
    // §00–§03 headings: each word slides up from 110% with spring stagger 40 ms.
    revealAll('.section-header__zh', { mode: 'words', threshold: 0.25, staggerMs: 40 });

    // ── 6. Parallax on ghost section numerals ─────────────────────────────────
    // .section-header__numeral overlays drift at 0.12× scroll speed — the giant
    // faint numerals appear to float slightly slower than the page content.
    document.querySelectorAll<HTMLElement>('.section-header__numeral').forEach((el) => {
      el.setAttribute('data-parallax', '');
      el.setAttribute('data-parallax-speed', '0.12');
    });
    initParallax();

    // ── 7. Spring reveal for prose / note blocks (.reveal class) ─────────────
    // Applies to .process-note, .types-intro, .cta-inner (translateY:24 + opacity).
    revealOnEnter('.reveal');

    // ── 8. Magnetic pull on clay CTAs + secondary links ──────────────────────
    // Spring-attracts toward cursor within 1.5× bounding box; snaps back spring.
    document.querySelectorAll<HTMLElement>('.cta--clay, .cta-secondary').forEach((el) => {
      bindMagnetic(el, { strength: 0.38, maxDisp: 18 });
    });

    // ── 9. Gold stroke-draw underlines on nav + footer links ─────────────────
    initLinkUnderlines();

    // ── 10. Spring count-up on numeric CTA stat values ───────────────────────
    // Targets [data-count-up][data-to] spans embedded in .cta-stat__value text.
    // E.g. "RTO ≤ 4hr" → the "4" span counts 0→4 with spring overshoot.
    const countUpEls = Array.from(
      document.querySelectorAll<HTMLElement>('[data-count-up][data-to]'),
    );
    if (countUpEls.length) {
      if (prefersReducedMotion()) {
        // Snap to final value immediately — no animation
        countUpEls.forEach((el) => {
          el.textContent = el.dataset.to ?? el.textContent;
        });
      } else {
        countUpEls.forEach((el) => {
          const to = Number(el.dataset.to ?? 0);
          el.textContent = '0';
          let fired = false;
          const io = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                if (!entry.isIntersecting || fired) continue;
                fired = true;
                const state = { val: 0 };
                // Spring overshoot: briefly exceeds target then settles
                animate(state as unknown as Record<string, number>, {
                  val:  [0, to],
                  ease: spring({ stiffness: 160, damping: 14, mass: 1.2 }),
                  onUpdate() {
                    el.textContent = String(Math.abs(Math.round(state.val)));
                  },
                  onComplete() {
                    el.textContent = String(to);
                  },
                });
                io.unobserve(el);
              }
            },
            { threshold: 0.3 },
          );
          io.observe(el);
        });
      }
    }

    // Only mount purely decorative canvas effects under full motion
    if (prefersReducedMotion()) return;

    // ── 11. Cursor-reactive dot-field behind sub-hero content ─────────────────
    // sub-hero__inner has position:relative + z-index:1 (Astro-scoped CSS),
    // creating a stacking context. Injecting a z:-1 wrapper as its first child
    // places the canvas below in-flow text but above the sibling SVG poster (z:0).
    const subHeroInner = document.querySelector<HTMLElement>('.sub-hero__inner');
    if (subHeroInner) {
      const heroDotBg = document.createElement('div');
      heroDotBg.setAttribute('aria-hidden', 'true');
      heroDotBg.style.cssText =
        'position:absolute;inset:0;z-index:-1;pointer-events:none;overflow:hidden;';
      subHeroInner.insertBefore(heroDotBg, subHeroInner.firstChild);
      mountDotField(heroDotBg, {
        cols:           40,
        rows:           18,
        dotRadius:      1.4,
        interactRadius: 120,
      });
    }

    // ── 12. Cursor-reactive dot-field behind §02 direct contact section ───────
    // .section--direct has position:relative + isolation:isolate in scoped CSS,
    // so the z:-1 dot-field wrapper is contained within the section (mirrors
    // .section--numbers on Home page §05).
    const directSection = document.querySelector<HTMLElement>('.section--direct');
    if (directSection) {
      const directDotBg = document.createElement('div');
      directDotBg.setAttribute('aria-hidden', 'true');
      directDotBg.style.cssText =
        'position:absolute;inset:0;z-index:-1;pointer-events:none;overflow:hidden;';
      directSection.insertBefore(directDotBg, directSection.firstChild);
      mountDotField(directDotBg, {
        cols:           22,
        rows:           10,
        dotRadius:      2.0,
        interactRadius: 120,
      });
    }

    // ── 13. Spring-stagger the direct-contact cards on scroll-enter ───────────
    // Four .direct-card panels cascade in from translateY(48) + scale(0.97)
    // with spring easing — NOT a plain opacity fade. Each card delays 70 ms.
    const directGrid = document.querySelector<HTMLElement>('.direct-grid');
    const directCards = directGrid
      ? Array.from(directGrid.querySelectorAll<HTMLElement>('.direct-card'))
      : [];
    if (directGrid && directCards.length) {
      directCards.forEach((c) => {
        c.style.opacity   = '0';
        c.style.transform = 'translateY(48px) scale(0.97)';
      });
      let firedDirect = false;
      const directIO = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (!e.isIntersecting || firedDirect) continue;
            firedDirect = true;
            animate(directCards, {
              opacity:    [0, 1],
              translateY: [48, 0],
              scale:      [0.97, 1],
              delay:      stagger(70, { ease: 'out(2)' }),
              ease:       spring({ stiffness: 220, damping: 22, mass: 1 }),
            });
            directIO.disconnect();
          }
        },
        { threshold: 0.15 },
      );
      directIO.observe(directGrid);
    }

    // ── 14. Spring-stagger the five inquiry-type cards on scroll-enter ─────────
    // Cards lift from translateY(48) + scale(0.97) in rapid editorial sequence.
    const inqGrid = document.querySelector<HTMLElement>('.inq-grid');
    const inqCards = inqGrid
      ? Array.from(inqGrid.querySelectorAll<HTMLElement>(':scope > [role="listitem"]'))
      : [];
    if (inqGrid && inqCards.length) {
      inqCards.forEach((c) => {
        c.style.opacity   = '0';
        c.style.transform = 'translateY(48px) scale(0.97)';
      });
      let firedInq = false;
      const inqIO = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (!e.isIntersecting || firedInq) continue;
            firedInq = true;
            animate(inqCards, {
              opacity:    [0, 1],
              translateY: [48, 0],
              scale:      [0.97, 1],
              delay:      stagger(60, { ease: 'out(2)' }),
              ease:       spring({ stiffness: 220, damping: 22, mass: 1 }),
            });
            inqIO.disconnect();
          }
        },
        { threshold: 0.08 },
      );
      inqIO.observe(inqGrid);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

<style>
  /* ── Contact scan wrapper — stacking context for SVG fallback ── */
  .contact-scan-wrapper {
    position: relative;
    isolation: isolate;
  }

  /* ─────────────────────────────────────────────────────────────────
     ENGAGE.00 — Process note
  ───────────────────────────────────────────────────────────────── */
  .process-note {
    margin-top: clamp(1.5rem, 4vw, 2.5rem);
    max-width: 64ch;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    color: var(--ink-faint);
    line-height: 1.65;
    border-left: 2px solid var(--border-strong);
    padding-left: 1.1rem;
  }

  /* ─────────────────────────────────────────────────────────────────
     DIRECT.02 — Stacking context for z:-1 dot-field wrapper
  ───────────────────────────────────────────────────────────────── */

  /*
   * position:relative + isolation:isolate creates a stacking context so the
   * z:-1 dot-field wrapper injected by the page script is contained within
   * this section — ember dots render BELOW the SectionHeader and direct-grid
   * content. Mirrors .section--numbers on the Home page.
   */
  .section--direct {
    position: relative;
    isolation: isolate;
    overflow: hidden;
  }

  /* ─────────────────────────────────────────────────────────────────
     DIRECT.02 — Contact grid
  ───────────────────────────────────────────────────────────────── */

  /* Gap-as-border: 1px gaps on dark bg create hairline dividers */
  .direct-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  @media (min-width: 640px) {
    .direct-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* ── Card shell ── */
  .direct-card {
    background: var(--surface);
    padding: clamp(1.25rem, 4vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  /* Accent top-hairline stripes */
  .direct-card--sun  { box-shadow: inset 0 2px 0 var(--sun);  }
  .direct-card--sage { box-shadow: inset 0 2px 0 var(--sage); }

  /* ── Kicker (label row above value) ── */
  .direct-card__kicker {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    color: var(--ink-faint);
    margin: 0;
  }

  /* ── Primary value ── */
  .direct-card__value {
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    font-weight: 600;
    color: var(--ink);
    margin: 0;
    line-height: 1.3;
  }

  /* Email link styling */
  .direct-card__email {
    color: var(--sun);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--sun) 40%, transparent);
    padding-bottom: 0.15rem;
    word-break: break-all;
    transition:
      color var(--dur-quick) var(--ease-out),
      border-color var(--dur-quick) var(--ease-out);
  }
  .direct-card__email:hover {
    color: var(--ink);
    border-color: var(--ink-muted);
  }
  .direct-card__email:focus-visible {
    outline: 2px solid var(--sun);
    outline-offset: 3px;
  }

  /* Monospaced geo-coordinate value */
  .direct-card__coords {
    font-family: var(--font-mono);
    font-size: clamp(1.1rem, 3.5vw, 1.5rem);
    letter-spacing: 0.05em;
  }

  /* ── Sub / secondary text ── */
  .direct-card__sub {
    font-size: 0.82rem;
    color: var(--ink-faint);
    line-height: 1.5;
    margin: 0;
  }

  /* ── Shared accent tag (sun / sage) ── */
  .accent-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    font-weight: 600;
    padding: 0.14em 0.48em;
    border-radius: 2px;
    border: 1px solid;
    align-self: flex-start;
    margin-top: auto;
  }
  .accent-tag--sun {
    color: var(--sun);
    border-color: color-mix(in srgb, var(--sun) 40%, transparent);
