---
import PageLayout from '../layouts/PageLayout.astro';
import SubHero from '../components/SubHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import DeliveryMatrix from '../components/DeliveryMatrix.astro';
import PhaseTimeline from '../components/PhaseTimeline.astro';
import SlaStrip from '../components/SlaStrip.astro';
import ComplianceBadges from '../components/ComplianceBadges.astro';
import RiskCard from '../components/RiskCard.astro';
import EngageCTA from '../components/EngageCTA.astro';
import { getCollection } from 'astro:content';
import { t, localized, withBase } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const risks = (await getCollection('risks')).sort((a, b) =>
  a.data.id.localeCompare(b.data.id),
);

const heroStats = [
  {
    value: t('methodology.hero.stat1.value', locale),
    label: t('methodology.hero.stat1.label', locale),
    sub: t('methodology.hero.stat1.sub', locale),
    accent: 'sage' as const,
  },
  {
    value: 'GB300',
    label: 'NVL72 AI Fabric',
    sub: t('methodology.hero.stat2.sub', locale),
  },
  {
    value: '≤4hr',
    label: 'DR RTO',
    sub: t('methodology.hero.stat3.sub', locale),
    accent: 'clay' as const,
  },
  {
    value: '≥95%',
    label: t('methodology.hero.stat4.label', locale),
    sub: t('methodology.hero.stat4.sub', locale),
    accent: 'sun' as const,
  },
];

const replSteps = [
  {
    num: '01',
    zh: t('methodology.section06.step1.zh', locale),
    en: 'TEMPLATE ARCHIVE',
    body: t('methodology.section06.step1.body', locale),
  },
  {
    num: '02',
    zh: t('methodology.section06.step2.zh', locale),
    en: 'GAP ASSESSMENT',
    body: t('methodology.section06.step2.body', locale),
  },
  {
    num: '03',
    zh: t('methodology.section06.step3.zh', locale),
    en: 'ACCELERATED DEPLOY',
    body: t('methodology.section06.step3.body', locale),
  },
];

const templateItems = [
  t('methodology.section06.templateItem1', locale),
  t('methodology.section06.templateItem2', locale),
  t('methodology.section06.templateItem3', locale),
  t('methodology.section06.templateItem4', locale),
  t('methodology.section06.templateItem5', locale),
];
---

<PageLayout
  title={t('page.methodology.title', locale)}
  description={t('page.methodology.description', locale)}
  locale={locale}
>
  <Fragment slot="hero">
    <SubHero
      eyebrow="FAB300 REFERENCE METHODOLOGY // SYSTEMS INTEGRATOR"
      zhTitle={t('methodology.hero.zhTitle', locale)}
      enLabel="INTELLIGENT WAFER FAB IT/OT+AI INTEGRATION METHODOLOGY"
      lede={t('methodology.hero.lede', locale)}
      stats={heroStats}
      ctas={[
        { href: withBase('/contact/'), label: t('cta.consult', locale), variant: 'clay' },
        { href: '#matrix', label: t('methodology.hero.cta2', locale), variant: 'ghost' },
      ]}
      locale={locale}
    />
  </Fragment>

  <!-- FIG.02: 六層×階段交付矩陣 ─────────────────────────── -->
  <section class="section" id="matrix" aria-labelledby="heading-02">
    <SectionHeader
      index="02"
      zh={t('methodology.section02.zh', locale)}
      en={t('methodology.section02.en', locale)}
    />
    <p class="fig-lede reveal">
      {t('methodology.section02.lede', locale)}
    </p>
    <div class="reveal">
      <DeliveryMatrix locale={locale} />
    </div>
  </section>

  <!-- FIG.03: 四階段交付 ──────────────────────────────────── -->
  <section class="section" id="timeline" aria-labelledby="heading-03">
    <SectionHeader
      index="03"
      zh={t('methodology.section03.zh', locale)}
      en={t('methodology.section03.en', locale)}
    />
    <p class="fig-lede reveal">
      {t('methodology.section03.lede', locale)}
    </p>
    <div class="reveal">
      <PhaseTimeline locale={locale} />
    </div>
    <div class="phase-detail reveal" aria-label={t('methodology.section03.phaseDetailAriaLabel', locale)}>
      <div class="phase-detail__row">
        <span class="phase-detail__tag phase-detail__tag--sage">{t('methodology.section03.p1.tag', locale)}</span>
        <p class="phase-detail__body">{t('methodology.section03.p1.body', locale)}</p>
      </div>
      <div class="phase-detail__row">
        <span class="phase-detail__tag phase-detail__tag--gold">{t('methodology.section03.p2.tag', locale)}</span>
        <p class="phase-detail__body">{t('methodology.section03.p2.body', locale)}</p>
      </div>
      <div class="phase-detail__row">
        <span class="phase-detail__tag phase-detail__tag--clay">{t('methodology.section03.p3.tag', locale)}</span>
        <p class="phase-detail__body">{t('methodology.section03.p3.body', locale)}</p>
      </div>
      <div class="phase-detail__row">
        <span class="phase-detail__tag phase-detail__tag--gold">{t('methodology.section03.p4.tag', locale)}</span>
        <p class="phase-detail__body">{t('methodology.section03.p4.body', locale)}</p>
      </div>
    </div>
  </section>

  <!-- FIG.04: 成果與承諾 ──────────────────────────────────── -->
  <section class="section" id="sla" aria-labelledby="heading-04">
    <SectionHeader
      index="04"
      zh={t('methodology.section04.zh', locale)}
      en={t('methodology.section04.en', locale)}
    />
    <p class="fig-lede reveal">
      {t('methodology.section04.lede', locale)}
    </p>
    <div class="reveal">
      <SlaStrip locale={locale} />
    </div>
    <div class="kpi-detail" aria-label={t('methodology.section04.kpiAriaLabel', locale)}>
      <div class="kpi-row">
        <span class="kpi-row__code kpi-row__code--gold">YLD.01</span>
        <div>
          <strong>{t('methodology.section04.kpi1.label', locale)}</strong>
          <p>{t('methodology.section04.kpi1.body', locale)}</p>
        </div>
      </div>
      <div class="kpi-row">
        <span class="kpi-row__code kpi-row__code--gold">SLO.02</span>
        <div>
          <strong>{t('methodology.section04.kpi2.label', locale)}</strong>
          <p>{t('methodology.section04.kpi2.body', locale)}</p>
        </div>
      </div>
      <div class="kpi-row">
        <span class="kpi-row__code kpi-row__code--clay">DR.03</span>
        <div>
          <strong>{t('methodology.section04.kpi3.label', locale)}</strong>
          <p>{t('methodology.section04.kpi3.body', locale)}</p>
        </div>
      </div>
      <div class="kpi-row">
        <span class="kpi-row__code kpi-row__code--clay">DR.04</span>
        <div>
          <strong>{t('methodology.section04.kpi4.label', locale)}</strong>
          <p>{t('methodology.section04.kpi4.body', locale)}</p>
        </div>
      </div>
      <div class="kpi-row">
        <span class="kpi-row__code kpi-row__code--sage">TPL.05</span>
        <div>
          <strong>{t('methodology.section04.kpi5.label', locale)}</strong>
          <p>{t('methodology.section04.kpi5.body', locale)}</p>
        </div>
      </div>
    </div>
    <div class="compliance-wrap reveal">
      <p class="compliance-label">{t('methodology.section04.complianceLabel', locale)}</p>
      <ComplianceBadges locale={locale} />
    </div>
    <p class="governance-note reveal">
      {t('methodology.section04.governanceNote', locale)}
    </p>
  </section>

  <!-- FIG.05: 風險與合規 ──────────────────────────────────── -->
  <section class="section section--deep" id="risk" aria-labelledby="heading-05">
    <SectionHeader
      index="05"
      zh={t('methodology.section05.zh', locale)}
      en={t('methodology.section05.en', locale)}
    />
    <p class="fig-lede reveal">
      {t('methodology.section05.lede', locale)}
    </p>
    <div class="risk-grid" role="list" aria-label={t('methodology.section05.riskGridAriaLabel', locale)} data-section-enter>
      {risks.map((r) => (
        <div role="listitem">
          <RiskCard
            id={r.data.id}
            zhRisk={localized(r.data, 'zhRisk', locale) as string}
            mitigation={localized(r.data, 'mitigation', locale) as string}
            tier={r.data.tier}
            locale={locale}
          />
        </div>
      ))}
    </div>
  </section>

  <!-- FIG.06: 跨廠複製藍圖 ────────────────────────────────── -->
  <section class="section" id="replication" aria-labelledby="heading-06">
    <SectionHeader
      index="06"
      zh={t('methodology.section06.zh', locale)}
      en={t('methodology.section06.en', locale)}
    />
    <p class="fig-lede reveal">
      {t('methodology.section06.lede', locale)}
    </p>

    <!-- 3-step process -->
    <ol class="repl-steps" aria-label={t('methodology.section06.stepsAriaLabel', locale)} data-section-enter>
      {replSteps.map((s) => (
        <li class="repl-step">
          <div class="repl-step__num" aria-hidden="true">{s.num}</div>
          <div class="repl-step__content">
            <h3 class="repl-step__zh">{s.zh}</h3>
            <p class="repl-step__en" aria-hidden="true">{s.en}</p>
            <p class="repl-step__body">{s.body}</p>
          </div>
        </li>
      ))}
    </ol>

    <!-- Template content checklist -->
    <div class="checklist-wrap reveal">
      <p class="checklist-label">
        <span class="checklist-label__dot" aria-hidden="true"></span>
        {t('methodology.section06.checklistLabel', locale)}
        <span class="checklist-label__en" aria-hidden="true">TEMPLATE CONTENT</span>
        <span class="checklist-badge checklist-badge--sage">COVERAGE</span>
      </p>
      <ul class="checklist" aria-label={t('methodology.section06.checklistAriaLabel', locale)}>
        {templateItems.map((item) => (
          <li class="checklist__item">
            <span class="checklist__status checklist__status--sage" aria-label={t('methodology.section06.archivedAriaLabel', locale)}>{t('methodology.section06.archivedLabel', locale)}</span>
            <span class="checklist__text">{item}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Honest disclaimer -->
    <div class="disclaimer reveal" role="note" aria-label={t('methodology.section06.disclaimerAriaLabel', locale)}>
      <span class="disclaimer__label" aria-hidden="true">// NOTE</span>
      <p class="disclaimer__text">
        {t('methodology.section06.disclaimerText', locale)}
      </p>
    </div>
  </section>

  <!-- ENGAGE CTA -->
  <EngageCTA locale={locale} />
</PageLayout>

<script>
  /**
   * MethodologyContent motion script — full cinematic engine matching Home.
   *
   * Boot order (DOMContentLoaded):
   *  1. bootMotion()           — HUD brackets draw-in, nav fade
   *  2. Sub-hero spring boot   — eyebrow, title, en-label, lede, stats, CTAs
   *  3. initCursor()           — gold ring HUD cursor
   *  4. initSmoothScroll()     — Lenis (no-op under reduced-motion)
   *  5. revealAll(…)           — spring word-stagger on section headings
   *  6. initParallax()         — ghost numerals counter-scroll at 0.12×
   *  7. initSectionEnter()     — spring-stagger risk cards + repl steps
   *  8. revealOnEnter('.reveal') — spring block reveal for .reveal elements
   *  9. fireKpiSignal()        — custom signal-travel down the §04 KPI table
   * 10. initSlaCountUp()       — spring overshoot count-up on .sla__value[data-to]
   * 11. bindMagnetic(…)        — magnetic CTAs
   * 12. initLinkUnderlines()   — gold stroke-draw underlines
   * 13. Dot-field (hero)       — cursor-reactive ember grid behind sub-hero
   * 14. Dot-field (risk)       — cursor-reactive ember grid behind §05 risk section
   *
   * Reduced-motion: every function is internally gated on prefersReducedMotion().
   */

  import {
    bootMotion,
    revealOnEnter,
    prefersReducedMotion,
  } from '../scripts/theme-motion';
  import { initCursor } from '../scripts/motion/cursor';
  import { initSmoothScroll } from '../scripts/motion/smooth-scroll';
  import { initParallax, initSectionEnter } from '../scripts/motion/scroll-fx';
  import { revealAll } from '../scripts/motion/text-reveal';
  import { bindMagnetic, initLinkUnderlines } from '../scripts/motion/magnetic';
  import { mount as mountDotField } from '../scripts/motion/dot-field';
  import { animate, stagger, spring, createTimeline } from 'animejs';

  // ─── KPI signal-travel (adapted for .kpi-detail table) ───────────────────────
  function fireKpiSignal(): void {
    if (prefersReducedMotion()) return;

    const kpiDetail = document.querySelector<HTMLElement>('.kpi-detail');
    if (!kpiDetail) return;

    const rows = Array.from(kpiDetail.querySelectorAll<HTMLElement>('.kpi-row'));
    if (!rows.length) return;

    // Hide rows so the signal reveals them on scroll-enter
    rows.forEach((row) => {
      row.style.opacity = '0';
      row.style.transform = 'translateX(-8px)';
    });

    // Glowing pulse pill that travels the left rail of the KPI table
    const pulse = document.createElement('div');
    pulse.setAttribute('aria-hidden', 'true');
    pulse.style.cssText = [
      'position:absolute', 'left:0', 'top:0',
      'width:2px', 'height:0', 'border-radius:1px',
      'background:linear-gradient(180deg,#E9C46A 0%,#E07A5F 100%)',
      'box-shadow:0 0 6px 2px rgba(233,196,106,0.45)',
      'pointer-events:none', 'z-index:3', 'opacity:0',
    ].join(';');

    kpiDetail.style.position = 'relative';
    kpiDetail.prepend(pulse);

    let fired = false;
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (!e.isIntersecting || fired) continue;
          fired = true;
          runSignal();
          const interval = setInterval(runSignal, 7000);
          // Cleanup interval when section leaves
          const exitIo = new IntersectionObserver((ex) => {
            if (!ex[0]?.isIntersecting) { clearInterval(interval); exitIo.disconnect(); }
          }, { threshold: 0 });
          exitIo.observe(kpiDetail);
        }
      },
      { threshold: 0.2 },
    );
    io.observe(kpiDetail);

    function runSignal() {
      if (prefersReducedMotion()) return;
      const kH = kpiDetail!.offsetHeight;
      pulse.style.height = '0';

      const tl = createTimeline({ defaults: { ease: 'out(2)' } });

      tl.add(pulse, { opacity: [0, 1], duration: 80 }, 0)
        .add(pulse, { height: [0, kH], duration: 820, ease: 'inOut(2)' }, 80);

      rows.forEach((row) => {
        const rowTop = row.getBoundingClientRect().top
          - kpiDetail!.getBoundingClientRect().top;
        const arrivalT = Math.round(80 + (rowTop / kH) * 820);
        tl.add(
          row,
          {
            opacity:    [0, 1],
            translateX: [-8, 0],
            duration: 300,
            ease: spring({ stiffness: 340, damping: 22, mass: 0.8 }),
          },
          arrivalT,
        );
      });

      tl.add(pulse, { opacity: [1, 0], duration: 260, ease: 'in(2)' }, 920);
    }
  }

  // ─── SLA count-up (port of initCountUp for .sla__value[data-to]) ─────────────
  function initSlaCountUp(): void {
    const els = Array.from(
      document.querySelectorAll<HTMLElement>('.sla__value[data-to]'),
    );
    if (!els.length) return;

    if (prefersReducedMotion()) {
      els.forEach((el) => {
        const prefix = el.dataset.prefix ?? '';
        const suffix = el.dataset.suffix ?? '';
        const to     = Number(el.dataset.to ?? 0);
        el.textContent = `${prefix}${to}${suffix}`;
      });
      return;
    }

    for (const el of els) {
      const to     = Number(el.dataset.to ?? 0);
      const prefix = el.dataset.prefix ?? '';
      const suffix = el.dataset.suffix ?? '';

      // Wrap prefix symbol if present so it can stroke in separately
      const hasSymbol = prefix.length > 0 && /[≤≥~<>]/.test(prefix);
      let prefixEl: HTMLElement | null = null;
      let valueSpan: HTMLElement | null = null;

      if (hasSymbol) {
        prefixEl = document.createElement('span');
        prefixEl.textContent = prefix;
        prefixEl.style.cssText = [
          'display:inline-block',
          'clip-path:inset(0 100% 0 0)',
          'transition:clip-path 400ms var(--ease-out)',
        ].join(';');
        el.textContent = '';
        el.appendChild(prefixEl);
        valueSpan = document.createElement('span');
        el.appendChild(valueSpan);
      } else {
        el.textContent = `${prefix}0${suffix}`;
      }

      let counted = false;
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (!e.isIntersecting || counted) continue;
            counted = true;

            if (prefixEl) {
              setTimeout(() => { prefixEl!.style.clipPath = 'inset(0 0% 0 0)'; }, 50);
            }

            const state = { val: 0 };
            const target: HTMLElement = valueSpan ?? el;

            animate(state as unknown as Record<string, number>, {
              val: [0, to],
              delay: hasSymbol ? 300 : 0,
              ease: spring({ stiffness: 160, damping: 14, mass: 1.2, velocity: 0 }),
              onUpdate() {
                const r = Math.abs(Math.round(state.val));
                target.textContent = prefixEl ? `${r}${suffix}` : `${prefix}${r}${suffix}`;
              },
              onComplete() {
                target.textContent = prefixEl ? `${to}${suffix}` : `${prefix}${to}${suffix}`;
              },
            });
            io.unobserve(el);
          }
        },
        { threshold: 0.3 },
      );
      io.observe(el);
    }
  }

  // ─── MAIN INIT ────────────────────────────────────────────────────────────────
  function init(): void {
    // ── 1. HUD brackets + nav fade (safe on pages without .hero__*) ────────────
    bootMotion();

    // ── 2. Sub-hero spring boot ─────────────────────────────────────────────────
    // bootMotion targets .hero__* classes; SubHero uses .sub-hero__* so we
    // animate the sub-page hero with a matching timeline.
    const reduced = prefersReducedMotion();

    const subHeroEyebrow = document.querySelector<HTMLElement>('.sub-hero__eyebrow');
    const subHeroTitle   = document.querySelector<HTMLElement>('.sub-hero__title');
    const subHeroEnLabel = document.querySelector<HTMLElement>('.sub-hero__en-label');
    const subHeroLede    = document.querySelector<HTMLElement>('.sub-hero__lede');
    const subHeroStats   = document.querySelectorAll<HTMLElement>('.sub-hero__stat');
    const subHeroCtas    = document.querySelectorAll<HTMLElement>('.sub-hero__ctas > *');

    if (reduced) {
      // Final states immediately — no animation
      [subHeroEyebrow, subHeroTitle, subHeroEnLabel, subHeroLede].forEach((el) => {
        if (el) { el.style.opacity = '1'; el.style.transform = 'none'; }
      });
      subHeroStats.forEach((el) => { el.style.opacity = '1'; el.style.transform = 'none'; });
      subHeroCtas.forEach((el)  => { el.style.opacity = '1'; el.style.transform = 'none'; });
    } else {
      // Set initial hidden states
      [subHeroEyebrow, subHeroTitle, subHeroEnLabel, subHeroLede].forEach((el) => {
        if (el) { el.style.opacity = '0'; el.style.transform = 'translateY(20px)'; }
      });
      subHeroStats.forEach((el) => {
        el.style.opacity = '0'; el.style.transform = 'translateY(16px)';
      });
      subHeroCtas.forEach((el) => {
        el.style.opacity = '0'; el.style.transform = 'translateY(12px)';
      });

      const tl = createTimeline({ defaults: { ease: 'out(3)' } });

      if (subHeroEyebrow) {
        tl.add(subHeroEyebrow, {
          opacity: [0, 1], translateY: [20, 0], duration: 400,
        }, 350);
      }
      if (subHeroTitle) {
        tl.add(subHeroTitle, {
          opacity:    [0, 1],
          translateY: [32, 0],
          duration:   540,
          ease:       spring({ stiffness: 260, damping: 22, mass: 0.9 }),
        }, 450);
      }
      if (subHeroEnLabel) {
        tl.add(subHeroEnLabel, {
          opacity: [0, 1], translateY: [14, 0], duration: 360,
        }, 640);
      }
      if (subHeroLede) {
        tl.add(subHeroLede, {
          opacity: [0, 1], translateY: [14, 0], duration: 360,
        }, 700);
      }
      if (subHeroStats.length) {
        tl.add(Array.from(subHeroStats), {
          opacity:    [0, 1],
          translateY: [16, 0],
          delay:      stagger(70),
          duration:   320,
          ease:       spring({ stiffness: 320, damping: 24 }),
        }, 780);
      }
      if (subHeroCtas.length) {
        tl.add(Array.from(subHeroCtas), {
          opacity:    [0, 1],
          translateY: [12, 0],
          delay:      stagger(80),
          duration:   300,
        }, 940);
      }
    }

    // ── 3. Custom HUD cursor ────────────────────────────────────────────────────
    initCursor();

    // ── 4. Lenis smooth scroll ──────────────────────────────────────────────────
    initSmoothScroll();

    // ── 5. Spring word-stagger on all section headings ──────────────────────────
    revealAll('.section-header__zh', { mode: 'words', threshold: 0.25, staggerMs: 40 });

    // ── 6. Parallax on ghost numerals ───────────────────────────────────────────
    document.querySelectorAll<HTMLElement>('.section-header__numeral').forEach((el) => {
      el.setAttribute('data-parallax', '');
      el.setAttribute('data-parallax-speed', '0.12');
    });
    initParallax();

    // ── 7. Spring-stagger section enters (.risk-grid, .repl-steps) ──────────────
    initSectionEnter();

    // ── 8. Spring block reveal for .reveal elements ─────────────────────────────
    revealOnEnter('.reveal');

    // ── 9. KPI signal-travel (gold→clay pulse down §04 KPI table) ───────────────
    fireKpiSignal();

    // ── 10. SLA count-up with spring overshoot ──────────────────────────────────
    initSlaCountUp();

    // ── 11. Magnetic pull on clay CTAs ──────────────────────────────────────────
    document.querySelectorAll<HTMLElement>('.cta--clay').forEach((el) => {
      bindMagnetic(el, { strength: 0.38, maxDisp: 20 });
    });

    // ── 12. Gold stroke-draw underlines on nav + footer links ───────────────────
    initLinkUnderlines();

    // Only mount dot-fields if motion is allowed
    if (prefersReducedMotion()) return;

    // ── 13. Cursor-reactive ember dot-field behind sub-hero ─────────────────────
    // Injected into .sub-hero__poster (z:0 in the sub-hero stacking context)
    // so it renders above the SVG background rings but below .sub-hero__inner (z:1).
    const subHeroPoster = document.querySelector<HTMLElement>('.sub-hero__poster');
    if (subHeroPoster) {
      const heroDotBg = document.createElement('div');
      heroDotBg.setAttribute('aria-hidden', 'true');
      heroDotBg.style.cssText =
        'position:absolute;inset:0;pointer-events:none;overflow:hidden;';
      subHeroPoster.appendChild(heroDotBg);
      mountDotField(heroDotBg, {
        cols:           32,
        rows:           18,
        dotRadius:      1.3,
        interactRadius: 110,
      });
    }

    // ── 14. Cursor-reactive ember dot-field behind §05 risk section ─────────────
    // .section--deep has isolation:isolate + overflow:hidden so z:-1 child is
    // contained and renders above the bg-deep color but below in-flow content.
    const riskSection = document.querySelector<HTMLElement>('.section--deep');
    if (riskSection) {
      const riskDotBg = document.createElement('div');
      riskDotBg.setAttribute('aria-hidden', 'true');
      riskDotBg.style.cssText =
        'position:absolute;inset:0;z-index:-1;pointer-events:none;overflow:hidden;';
      riskSection.insertBefore(riskDotBg, riskSection.firstChild);
      mountDotField(riskDotBg, {
        cols:           26,
        rows:           14,
        dotRadius:      2.0,
        interactRadius: 130,
