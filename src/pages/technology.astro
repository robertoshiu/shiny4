---
import PageLayout from '../layouts/PageLayout.astro';
import SubHero from '../components/SubHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import HardwareTable from '../components/HardwareTable.astro';
import SecurityZoneDiagram from '../components/SecurityZoneDiagram.astro';
import ComplianceMatrix from '../components/ComplianceMatrix.astro';
import EngageCTA from '../components/EngageCTA.astro';
import { getCollection } from 'astro:content';

const locale = 'zh-Hant' as const;

/* ── Data fetching ─────────────────────────────────────────────────────────── */
const allTech = await getCollection('techComponents');

const NET_ORDER: Record<string, number> = {
  'Quantum-X800': 0,
  'Spectrum-X-SN5600': 1,
  'ConnectX-8': 2,
};
const networkComps = allTech
  .filter((c) => c.data.domain === 'network')
  .sort((a, b) => (NET_ORDER[a.data.id] ?? 9) - (NET_ORDER[b.data.id] ?? 9));

const mesComp = allTech.find((c) => c.data.id === 'FAB300')!;

const DAI_ORDER: Record<string, number> = {
  Historian: 0,
  'Lakehouse-EDA': 1,
  'Digital-Twin': 2,
  'Agentic-RAG': 3,
};
const dataAIComps = allTech
  .filter((c) => c.data.domain === 'data-AI')
  .sort((a, b) => (DAI_ORDER[a.data.id] ?? 9) - (DAI_ORDER[b.data.id] ?? 9));

const DR_ORDER: Record<string, number> = {
  'DR-WarmStandby': 0,
  'DR-AsyncReplication': 1,
  'DR-SDWAN': 2,
  'DR-HGX-B300': 3,
};
const drComps = allTech
  .filter((c) => c.data.domain === 'DR')
  .sort((a, b) => (DR_ORDER[a.data.id] ?? 9) - (DR_ORDER[b.data.id] ?? 9));

/* ── Static reference data ─────────────────────────────────────────────────── */
const ACCENT_LABEL: Record<string, string> = {
  clay: 'RESILIENCE',
  sun: 'PERFORMANCE',
  sage: 'COVERAGE',
};

const NET_ACCENT: Record<string, 'clay' | 'sun' | 'sage'> = {
  'Quantum-X800': 'sage',
  'Spectrum-X-SN5600': 'sage',
  'ConnectX-8': 'sun',
};

const DAI_ACCENT: Record<string, 'clay' | 'sun' | 'sage'> = {
  Historian: 'sage',
  'Lakehouse-EDA': 'sun',
  'Digital-Twin': 'sun',
  'Agentic-RAG': 'sun',
};

/* FAB300 seven modules — verbatim from content-inventory §03 */
const mesModules = [
  { idx: '01', en: 'Dispatching',       zh: 'WIP 調度' },
  { idx: '02', en: 'Genealogy',         zh: '譜系追溯' },
  { idx: '03', en: 'APC · R2R + FDC',  zh: '先進製程控制' },
  { idx: '04', en: 'Recipe / RMS',      zh: '配方管理' },
  { idx: '05', en: 'Scheduling / APS',  zh: '排程規劃' },
  { idx: '06', en: 'SPC / YMS',         zh: '統計製程控制 · 良率管理' },
  { idx: '07', en: 'EAP / SECS-GEM',   zh: '設備整合 · GEM300 協議' },
];

/* Layer nav — L2-L6 mapped to the 6 content sections on this page */
const layerNav = [
  { layer: 'L3', zh: '算力底座',     href: '#compute'   },
  { layer: 'L3', zh: '網絡 Fabric',  href: '#network'   },
  { layer: 'L4', zh: 'MES FAB300',   href: '#mes'       },
  { layer: 'L2', zh: '數據 · AI',    href: '#data-ai'   },
  { layer: 'L5', zh: '資訊安全',      href: '#security'  },
  { layer: 'L6', zh: '韌性備援',      href: '#dr'        },
];

/* Hero stats — from content-inventory §Hero */
const heroStats = [
  { value: 'GB300 ×3', label: 'AI GPU 算力',   sub: 'Blackwell Ultra · NVL72 液冷', accent: 'sun'  as const },
  { value: '4PB',      label: '儲存容量',       sub: 'NVMe Lakehouse · 高頻全鏈路',  accent: 'sun'  as const },
  { value: '≤ 4hr',   label: 'DR 韌性',        sub: 'RTO · 溫備援 · 季度實測演練',  accent: 'clay' as const },
  { value: '7',        label: 'FAB300 模組',    sub: 'MES 核心 · HVM 旗艦',          accent: 'sage' as const },
];
---

<PageLayout
  title="技術底座 — 顯藝科技 SHINYLOGIC"
  description="FAB300 技術深探：GB300 NVL72 Blackwell Ultra 算力底座、Quantum-X800 800Gb/s 網絡 Fabric、高量產 MES 七模組、數據與 AI 平台、OT/IT 資安三域架構、DR 備援與五項合規基準。"
  locale={locale}
>
  <!-- Hero slot: SubHero only (overflow:hidden on page-hero is safe here) -->
  <Fragment slot="hero">
    <SubHero
      eyebrow="工程技術深探 // ENGINEERING DEEP-DIVE"
      zhTitle="智能晶圓廠的技術底座"
      enLabel="TECHNOLOGY · L1–L6 ENGINEERING DEPTH"
      lede="從 L1 設備訊號到 L6 備援層，每一層以確定規格、明確 SLA 與工業級架構交付 — 不以估算代替實測，不以假設取代演練。"
      stats={heroStats}
      ctas={[{ href: '/contact/', label: '預約諮詢', variant: 'clay' }]}
    />
  </Fragment>

  <!-- Sticky L1-L6 layer-nav strip (in main, outside overflow:hidden hero) -->
  <nav class="layer-nav" aria-label="架構層級快速導覽">
    <div class="layer-nav__inner">
      {layerNav.map((item) => (
        <a class="layer-nav__item" href={item.href}>
          <span class="layer-nav__layer" aria-hidden="true">{item.layer}</span>
          <span class="layer-nav__zh">{item.zh}</span>
        </a>
      ))}
    </div>
  </nav>

  <!-- ── 01 Blackwell Ultra 算力底座 ──────────────────────────────────────── -->
  <section class="section" id="compute" aria-labelledby="heading-01">
    <SectionHeader index="01" zh="Blackwell Ultra 算力底座" en="AI COMPUTE · L3" />
    <p class="section-lede reveal">
      3 × GB300 NVL72 整機櫃 AI 系統（液冷 · Blackwell Ultra）組成主力 AI Fabric；4 × HGX B300
      承擔邊緣推理與備援算力；NVMe 數據湖覆蓋 EDA 高頻波形至訓練特徵全鏈路儲存。
    </p>
    <HardwareTable />
  </section>

  <!-- ── 02 高速網絡 Fabric ─────────────────────────────────────────────── -->
  <section class="section" id="network" aria-labelledby="heading-02">
    <SectionHeader index="02" zh="高速網絡 Fabric" en="NETWORK FABRIC · L3" />
    <div class="net-grid reveal">
      {networkComps.map((comp) => {
        const accent = NET_ACCENT[comp.data.id] ?? 'sage';
        return (
          <article class={`net-card net-card--${accent}`}>
            <header class="net-card__hd">
              <span
                class={`net-card__tag net-card__tag--${accent}`}
                aria-label={`角色：${ACCENT_LABEL[accent]}`}
              >
                {ACCENT_LABEL[accent]}
              </span>
              <h3 class="net-card__name">{comp.data.zhName}</h3>
            </header>
            <p class="net-card__spec">{comp.data.spec}</p>
            {comp.data.note && <p class="net-card__note">{comp.data.note}</p>}
          </article>
        );
      })}
    </div>
    <!-- Three summary stats from content-inventory §02 -->
    <div class="net-stats" role="list" aria-label="網絡關鍵指標">
      <div class="net-stat net-stat--sage" role="listitem">
        <span class="net-stat__value">800Gb/s</span>
        <span class="net-stat__label">東西向 AI Fabric 頻寬</span>
        <span class="net-stat__badge">COVERAGE</span>
      </div>
      <div class="net-stat net-stat--sage" role="listitem">
        <span class="net-stat__value">144</span>
        <span class="net-stat__label">Quantum-X800 交換埠位</span>
        <span class="net-stat__badge">COVERAGE</span>
      </div>
      <div class="net-stat net-stat--sun" role="listitem">
        <span class="net-stat__value">ConnectX-8</span>
        <span class="net-stat__label">每 GPU 節點 SuperNIC</span>
        <span class="net-stat__badge">PERFORMANCE</span>
      </div>
    </div>
  </section>

  <!-- ── 03 高量產 MES 平台（FAB300）──────────────────────────────────────── -->
  <section class="section" id="mes" aria-labelledby="heading-03">
    <SectionHeader index="03" zh="高量產 MES 平台（FAB300）" en="MES · FAB300 · L4" />
    <div class="mes-layout">
      <!-- 7-module map -->
      <div class="mes-modules reveal" role="list" aria-label="FAB300 七核心模組">
        {mesModules.map((mod) => (
          <div class="mes-module" role="listitem">
            <span class="mes-module__idx" aria-hidden="true">{mod.idx}</span>
            <div class="mes-module__body">
              <span class="mes-module__en">{mod.en}</span>
              <span class="mes-module__zh">{mod.zh}</span>
            </div>
          </div>
        ))}
      </div>

      <!-- Key facts sidebar -->
      <aside class="mes-facts reveal" aria-label="FAB300 關鍵規格">
        <p class="mes-facts__hud" aria-hidden="true">X:0610 Y:MES · FAB300</p>
        <h3 class="mes-facts__title">{mesComp.data.zhName}</h3>
        <p class="mes-facts__spec">{mesComp.data.spec}</p>
        <dl class="mes-dl">
          <div class="mes-dl__row">
            <dt class="mes-dl__dt">定位</dt>
            <dd class="mes-dl__dd">HVM 高量產旗艦 MES 龍頭</dd>
          </div>
          <div class="mes-dl__row">
            <dt class="mes-dl__dt">授權 + 實施</dt>
            <dd class="mes-dl__dd">依合約議定授權規模；7 模組現場實施</dd>
          </div>
          <div class="mes-dl__row">
            <dt class="mes-dl__dt">EAP 聯調</dt>
            <dd class="mes-dl__dd">8 工藝機台 SECS-GEM / GEM300</dd>
          </div>
          <div class="mes-dl__row">
            <dt class="mes-dl__dt">年維護</dt>
            <dd class="mes-dl__dd">依合約 SLA</dd>
          </div>
          <div class="mes-dl__row">
            <dt class="mes-dl__dt">企業整合</dt>
            <dd class="mes-dl__dd">ISA-95 L3↔L4 · ERP / PLM / AMHS / LIMS / FMCS</dd>
          </div>
        </dl>
        {mesComp.data.note && (
          <aside class="mes-facts__note" aria-label="模組詳細說明">
            <span class="mes-facts__note-badge">MODULE NOTE</span>
            <span class="mes-facts__note-text">{mesComp.data.note}</span>
          </aside>
        )}
      </aside>
    </div>
  </section>

  <!-- ── 04 數據與 AI 平台 ──────────────────────────────────────────────── -->
  <section class="section" id="data-ai" aria-labelledby="heading-04">
    <SectionHeader index="04" zh="數據與 AI 平台" en="DATA & AI · L2 / L4" />
    <div class="dai-grid">
      {dataAIComps.map((comp) => {
        const accent = DAI_ACCENT[comp.data.id] ?? 'sun';
        return (
          <article class={`dai-card dai-card--${accent} reveal`}>
            <header class="dai-card__hd">
              <span class={`dai-card__tag dai-card__tag--${accent}`}>
                {ACCENT_LABEL[accent]}
              </span>
              <h3 class="dai-card__name">{comp.data.zhName}</h3>
            </header>
            <p class="dai-card__spec">{comp.data.spec}</p>
            {comp.data.note && <p class="dai-card__note">{comp.data.note}</p>}
          </article>
        );
      })}
    </div>
  </section>

  <!-- ── 05 資訊安全 OT/IT ──────────────────────────────────────────────── -->
  <section class="section" id="security" aria-labelledby="heading-05">
    <SectionHeader index="05" zh="資訊安全 OT/IT" en="SECURITY · L5" />
    <SecurityZoneDiagram />
  </section>

  <!-- ── 06 韌性與異地備援 ──────────────────────────────────────────────── -->
  <section class="section" id="dr" aria-labelledby="heading-06">
    <SectionHeader index="06" zh="韌性與異地備援" en="RESILIENCE · DR · L6" />

    <!-- Two KPI stat blocks — clay accent (resilience) per tri-accent system -->
    <div class="dr-kpi reveal" aria-label="DR 關鍵指標">
      <div class="dr-kpi__stat">
        <span class="dr-kpi__value">≤ 4hr</span>
        <span class="dr-kpi__label">DR RTO</span>
        <span class="dr-kpi__sub">關鍵系統復原時間目標</span>
        <span class="dr-kpi__badge">RESILIENCE</span>
      </div>
      <div class="dr-kpi__stat">
        <span class="dr-kpi__value">≤ 15min</span>
        <span class="dr-kpi__label">DR RPO</span>
        <span class="dr-kpi__sub">數據復原點目標 · 異步複製</span>
        <span class="dr-kpi__badge">RESILIENCE</span>
      </div>
    </div>

    <!-- DR architecture table — 4 components from collection -->
    <div
      class="dr-scroll"
      role="region"
      aria-label="DR 架構配置表，可橫向捲動"
    >
      <table class="dr-table" aria-label="異地備援架構配置表">
        <thead>
          <tr>
            <th class="dr-th dr-th--name" scope="col">
              <span class="dr-th__zh">架構項目</span>
              <span class="dr-th__en">COMPONENT</span>
            </th>
            <th class="dr-th dr-th--spec" scope="col">
              <span class="dr-th__zh">規格</span>
              <span class="dr-th__en">SPEC</span>
            </th>
            <th class="dr-th dr-th--note" scope="col">
              <span class="dr-th__zh">說明</span>
              <span class="dr-th__en">NOTE</span>
            </th>
          </tr>
        </thead>
        <tbody>
          {drComps.map((comp) => (
            <tr class="dr-tr">
              <td class="dr-td dr-td--name">
                <span class="dr-name">{comp.data.zhName}</span>
              </td>
              <td class="dr-td dr-td--spec">
                <span class="dr-spec">{comp.data.spec}</span>
              </td>
              <td class="dr-td dr-td--note">
                {comp.data.note
                  ? <span class="dr-note">{comp.data.note}</span>
                  : <span class="dr-note-empty" aria-hidden="true">—</span>
                }
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- ── 07 合規基準 ────────────────────────────────────────────────────── -->
  <section class="section" id="compliance" aria-labelledby="heading-07">
    <SectionHeader index="07" zh="合規基準" en="COMPLIANCE · L5" />
    <ComplianceMatrix />
  </section>

  <EngageCTA locale={locale} />
</PageLayout>

<script>
  import { revealOnEnter } from '../scripts/theme-motion';
  revealOnEnter('.reveal');

  // Scroll-spy: highlight active layer-nav item as sections enter viewport
  const navItems = Array.from(
    document.querySelectorAll<HTMLAnchorElement>('.layer-nav__item'),
  );
  const sectionIds = ['compute', 'network', 'mes', 'data-ai', 'security', 'dr'];
  const sections = sectionIds.map((id) => document.getElementById(id));

  if (navItems.length && sections.some(Boolean)) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            navItems.forEach((a) => {
              a.classList.toggle('is-active', a.getAttribute('href') === `#${id}`);
            });
          }
        });
      },
      { threshold: 0.2, rootMargin: '-10% 0px -60% 0px' },
    );
    sections.forEach((s) => s && observer.observe(s));
  }
</script>

<style>
  /* ── Section layout ──────────────────────────────────────────────────────── */
  /* scroll-margin-top: sticky layer-nav (44px) + fixed header (68px) */
  #compute, #network, #mes, #data-ai, #security, #dr, #compliance {
    scroll-margin-top: calc(68px + 44px);
  }

  .section-lede {
    max-width: 62ch;
    color: var(--ink-muted);
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  /* ── Sticky L1–L6 layer nav ─────────────────────────────────────────────── */
  .layer-nav {
    position: sticky;
    top: 68px; /* sits below fixed site-header (~68px tall) */
    z-index: 20;
    background: color-mix(in srgb, var(--bg-deep) 94%, transparent);
    backdrop-filter: blur(8px);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border-strong);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .layer-nav::-webkit-scrollbar {
    display: none;
  }

  .layer-nav__inner {
    display: flex;
    align-items: stretch;
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  .layer-nav__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.18rem;
    padding: 0.65rem 1.1rem;
    text-decoration: none;
    border-right: 1px solid var(--border);
    color: var(--ink-muted);
    white-space: nowrap;
    transition:
      color var(--dur-instant) var(--ease-out),
      background var(--dur-instant) var(--ease-out);
  }
  .layer-nav__item:last-child {
    border-right: none;
  }
  .layer-nav__item:hover {
    color: var(--ink);
    background: color-mix(in srgb, var(--sun) 5%, transparent);
  }
  .layer-nav__item.is-active {
    color: var(--ink);
    background: color-mix(in srgb, var(--sun) 7%, transparent);
    box-shadow: inset 0 -2px 0 var(--sun);
  }

  .layer-nav__layer {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.15em;
    color: var(--sun);
    font-weight: 600;
  }
  .layer-nav__item.is-active .layer-nav__layer {
    color: var(--sun);
  }

  .layer-nav__zh {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    line-height: 1.2;
  }

  /* ── 02 Network cards ───────────────────────────────────────────────────── */
  .net-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border-strong);
    border: 1px solid var(--border-strong);
    margin-bottom: 0; /* flush with stats strip */
  }
  @media (max-width: 768px) {
    .net-grid {
      grid-template-columns: 1fr;
    }
  }

  .net-card {
    background: var(--surface);
    padding: clamp(1.5rem, 3vw, 2.25rem);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .net-card--sage { box-shadow: inset 0 3px 0 var(--sage); }
  .net-card--sun  { box-shadow: inset 0 3px 0 var(--sun);  }
  .net-card--clay { box-shadow: inset 0 3px 0 var(--clay); }

  .net-card__hd {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .net-card__tag {
    font-family: var(--font-mono);
    font-size: 0.60rem;
    letter-spacing: 0.16em;
    font-weight: 600;
    padding: 0.15em 0.5em;
    border-radius: 2px;
    border: 1px solid;
    align-self: flex-start;
  }
  .net-card__tag--sage {
    color: var(--sage);
    border-color: color-mix(in srgb, var(--sage) 40%, transparent);
    background: color-mix(in srgb, var(--sage) 8%, transparent);
  }
  .net-card__tag--sun {
    color: var(--sun);
    border-color: color-mix(in srgb, var(--sun) 40%, transparent);
    background: color-mix(in srgb, var(--sun) 8%, transparent);
  }

  .net-card__name {
    font-family: var(--font-mono);
    font-size: clamp(1rem, 2.2vw, 1.2rem);
    font-weight: 600;
    color: var(--ink);
    line-height: 1.2;
    margin: 0;
  }

  .net-card__spec {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--ink-muted);
    line-height: 1.6;
    margin: 0;
  }

  .net-card__note {
    font-size: 0.82rem;
    color: var(--ink-muted);
    line-height: 1.55;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
    margin: auto 0 0; /* push to bottom of card */
  }

  /* Three summary stats — flush below the card grid */
  .net-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid var(--border-strong);
    border-top: none;
    background: var(--bg-deep);
    margin-top: 0;
  }
  @media (max-width: 600px) {
    .net-stats {
      grid-template-columns: 1fr;
    }
  }

  .net-stat {
    padding: 1.1rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    border-right: 1px solid var(--border);
  }
  .net-stat:last-child {
    border-right: none;
  }
  .net-stat--sage { box-shadow: inset 0 2px 0 var(--sage); }
  .net-stat--sun  { box-shadow: inset 0 2px 0 var(--sun);  }

  .net-stat__value {
    font-family: var(--font-mono);
    font-size: clamp(1.05rem, 2.5vw, 1.5rem);
    font-weight: 500;
    line-height: 1;
  }
  .net-stat--sage .net-stat__value { color: var(--sage); }
  .net-stat--sun  .net-stat__value { color: var(--sun);  }

  .net-stat__label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.3;
  }

  .net-stat__badge {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.15em;
    font-weight: 600;
    margin-top: 0.15rem;
  }
  .net-stat--sage .net-stat__badge { color: var(--sage); opacity: 0.7; }
  .net-stat--sun  .net-stat__badge { color: var(--sun);  opacity: 0.7; }

  /* ── 03 MES Layout ──────────────────────────────────────────────────────── */
  .mes-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }
