---
import PageLayout from '../layouts/PageLayout.astro';
import SubHero from '../components/SubHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SlaStrip from '../components/SlaStrip.astro';
import ComplianceBadges from '../components/ComplianceBadges.astro';
import BuildVsBuy from '../components/BuildVsBuy.astro';
import EngageCTA from '../components/EngageCTA.astro';
import LayerStack from '../components/LayerStack.astro';
import SolutionBlock from '../components/SolutionBlock.astro';
import { getCollection } from 'astro:content';

const locale = 'zh-Hant' as const;

/** Sort solutions to inventory order (no order field in schema — sorted by filename). */
const SOL_ORDER = [
  'ai-compute',
  'mes',
  'network-fabric',
  'ot-it-security',
  'dr',
  'enterprise-integration',
];
const solutions = (await getCollection('solutions')).sort(
  (a, b) => SOL_ORDER.indexOf(a.id) - SOL_ORDER.indexOf(b.id),
);

/**
 * Hero stats (verbatim from content inventory §Page 3 "Hero stats"):
 *   六層架構堆疊：6 · 解決方案域：6 · 系統SLO：≥ 95% · DR RTO：≤ 4hr
 * Tri-accent: sage=coverage/architecture · sun=performance/SLO · clay=resilience/DR
 */
const heroStats = [
  { value: '6',     label: '架構層數',    sub: 'L1 輸入 → L6 備援',         accent: 'sage' as const },
  { value: '6',     label: '解決方案域',  sub: '每層對應一類工程問題' },
  { value: '≥95%',  label: '系統 SLO',   sub: '量產期 SOC 24×7 持續監控',   accent: 'sun'  as const },
  { value: '≤4hr',  label: 'DR RTO',     sub: '季度實測演練 · 有憑有據',     accent: 'clay' as const },
];

/**
 * Governance pillars for SOL.04 (source: content-inventory §Outcomes & SLA).
 * Rendered as a compact 5-item list under the SLA strip.
 */
const govPillars = [
  { code: 'GATE',    zh: '8道Gate交付管控',     detail: '四階段 · 逐道提交驗收文件後才進入下一階段' },
  { code: 'RACI',    zh: 'RACI唯一責任人',       detail: '每議題唯一A（Accountable）· 無責任真空' },
  { code: 'RISK',    zh: '風險三級升級機制',     detail: '綠/黃/紅 · 黃級48小時升委員會 · 紅級即時上報' },
  { code: 'DR',      zh: 'DR演練季度閉環',       detail: 'RTO ≤ 4hr實測紀錄存檔 · 納入下季Review' },
  { code: 'ARCHIVE', zh: '100%跨廠模板歸檔',     detail: '交付完成後全套文件移交 · 可在每座新廠複製套用' },
];
---

<PageLayout
  title="解決方案 — 顯藝科技 SHINYLOGIC"
  description="顯藝科技六層全棧解決方案：AI算力與儲存、製造執行MES、高速網絡Fabric、資訊安全OT/IT、異地備援DR、企業整合 — 每層對應一類問題域，以明確SLA保障交付。"
>
  <!-- ── HERO ── -->
  <Fragment slot="hero">
    <SubHero
      eyebrow="解決方案 · 六層全棧 // SOLUTIONS OVERVIEW"
      zhTitle="每一層，解決一類問題。"
      enLabel="SIX LAYERS · SIX SOLUTION DOMAINS · ONE CONTRACTUAL SLA"
      lede="顯藝科技不交付模組，而是交付覆蓋L1至L6的全棧責任 — 從設備訊號到備援架構，每一層都有明確的問題定義、交付範圍與可驗收規格。"
      stats={heroStats}
      ctas={[
        { href: '#sol-blocks',   label: '探索六大解決方案', variant: 'clay' },
        { href: '/contact/',     label: '預約諮詢',          variant: 'ghost' },
      ]}
    />
  </Fragment>

  <!-- ── SOL.02 六層架構→六解決框架 ── -->
  <section class="section" id="sol-framework" aria-labelledby="heading-02">
    <div class="section__inner">
      <SectionHeader index="02" zh="六層架構，六個解決框架" en="SOLUTION FRAMEWORK" />
      <p class="section__lead reveal">
        六層架構不是分層圖示 — 它是六個可獨立驗收的工程問題域。每一層對應一類真實挑戰：
        從異質協議孤立（L1）、高頻數據無法支撐AI（L2）、超算算力部署（L3）、決策閉環無法規模化（L4），
        到OT/IT合規邊界模糊（L5），以及晶圓廠停機成本過高（L6）。
      </p>
      <LayerStack />
    </div>
  </section>

  <!-- ── SOL.03 六大解決方案 ── -->
  <section class="section section--alt" id="sol-blocks" aria-labelledby="heading-03">
    <div class="section__inner">
      <SectionHeader index="03" zh="六大解決方案，逐一深解" en="SOLUTION BLOCKS" />
      <p class="section__lead reveal">
        點選任一方案可展開交付範圍與關鍵規格。所有數字均為合約條款，可驗收，非估算。
      </p>
      <div class="sol-grid">
        {solutions.map((entry, i) => (
          <SolutionBlock
            id={entry.data.id}
            zhName={entry.data.zhName}
            enLabel={entry.data.enLabel}
            problem={entry.data.problem}
            scope={entry.data.scope}
            keySpecs={entry.data.keySpecs}
            sharePct={entry.data.sharePct}
            index={i}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ── SOL.04 成果與承諾 ── -->
  <section class="section" id="outcomes" aria-labelledby="heading-04">
    <div class="section__inner">
      <SectionHeader index="04" zh="成果與承諾" en="OUTCOMES & SLA" />
      <p class="section__lead reveal">
        六項 KPI 承諾源自同一套合約 SLA — 不是目標，是可稽核的交付條件。
      </p>

      <!-- 6-KPI SLA strip -->
      <div class="outcomes__sla reveal">
        <SlaStrip />
      </div>

      <!-- Compliance badges -->
      <div class="outcomes__compliance reveal">
        <h3 class="outcomes__sub-heading">
          <span class="outcomes__sub-kicker">COMPLIANCE BASIS</span>合規底座
        </h3>
        <ComplianceBadges />
      </div>

      <!-- Governance summary — 5 pillars -->
      <div class="outcomes__gov reveal" aria-label="治理架構摘要">
        <h3 class="outcomes__sub-heading">
          <span class="outcomes__sub-kicker">GOVERNANCE</span>治理架構
        </h3>
        <ul class="gov-list" role="list">
          {govPillars.map((p) => (
            <li class="gov-item">
              <span class="gov-item__code" aria-hidden="true">{p.code}</span>
              <div class="gov-item__body">
                <strong class="gov-item__zh">{p.zh}</strong>
                <span class="gov-item__detail">{p.detail}</span>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ── SOL.05 為何委外而非自建 — BuildVsBuy (全頁共用元件) ── -->
  <BuildVsBuy index="05" />

  <!-- ── ENGAGE ── -->
  <EngageCTA locale={locale} />
</PageLayout>

<script>
  import { revealOnEnter } from '../scripts/theme-motion';
  revealOnEnter('.reveal');
</script>

<style>
  /* ── Section scaffolding ── */
  .section {
    padding: clamp(4rem, 10vw, 7rem) var(--gutter);
  }
  .section--alt {
    background: var(--bg-deep);
  }

  .section__inner {
    max-width: var(--maxw);
    margin-inline: auto;
  }

  .section__lead {
    font-size: clamp(0.95rem, 2vw, 1.1rem);
    color: var(--ink-muted);
    line-height: 1.75;
    max-width: 60ch;
    margin: 0 0 clamp(2rem, 5vw, 3.5rem);
  }

  /* ── SOL.03 solution grid — single column on mobile; 2-col on ≥768px ── */
  .sol-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  @media (min-width: 768px) {
    .sol-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ── SOL.04 Outcomes layout ── */
  .outcomes__sla {
    margin-bottom: clamp(2.5rem, 6vw, 4rem);
  }

  .outcomes__compliance {
    margin-bottom: clamp(2.5rem, 6vw, 4rem);
  }

  .outcomes__sub-heading {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 1rem;
  }

  .outcomes__sub-kicker {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    color: var(--ink-faint);
    font-weight: 400;
  }

  /* ── Governance pillar list ── */
  .gov-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  @media (min-width: 640px) {
    .gov-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .gov-list {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  .gov-item {
    background: var(--surface);
    padding: clamp(1.25rem, 3vw, 1.75rem);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    /* Sage top hairline: governance = coverage/archive (DESIGN.md tri-accent) */
    box-shadow: inset 0 2px 0 var(--sage);
  }

  .gov-item__code {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: var(--sage);
    font-weight: 600;
  }

  .gov-item__body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .gov-item__zh {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.3;
  }

  .gov-item__detail {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ink-muted);
    line-height: 1.55;
    letter-spacing: 0.02em;
  }
</style>
