---
import PageLayout from '../layouts/PageLayout.astro';
import SubHero from '../components/SubHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import LayerStack from '../components/LayerStack.astro';
import ComplianceBadges from '../components/ComplianceBadges.astro';
import PhaseTimeline from '../components/PhaseTimeline.astro';
import EngageCTA from '../components/EngageCTA.astro';

const locale = 'zh-Hant' as const;
---

<PageLayout
  title="關於顯藝科技 SHINYLOGIC — 使命、治理與交付能力"
  description="顯藝科技為高量產晶圓廠直接承擔 IT/OT+AI 全棧建置、整合與維運全程責任。六層架構、八道 Gate 治理、DR 季度實測、100% 知識歸檔移交。FAB300 參考建置，NVIDIA GB300 NVL72 算力底座。"
  heroVariant="sub"
  locale={locale}
>
  <Fragment slot="hero">
    <SubHero
      eyebrow="WHO WE ARE // SYSTEMS INTEGRATOR"
      zhTitle="關於顯藝科技"
      enLabel="ABOUT SHINYLOGIC · INTELLIGENT WAFER FAB SYSTEMS"
      lede="顯藝科技為高量產晶圓廠直接承擔 IT/OT+AI 全棧的建置、整合與維運全程責任，以明確 SLA 保障交付品質，以 FAB300 為參考建置，以 NVIDIA GB300 NVL72 為算力底座。"
      stats={[
        { value: '≤4hr', label: 'DR RTO', sub: 'RPO ≤ 15min · 溫備援跨區域', accent: 'clay' },
        { value: '≥95%', label: '系統 SLO', sub: '量產期持續監控', accent: 'sun' },
        { value: '100%', label: '知識歸檔', sub: '跨廠範本移交', accent: 'sage' },
        { value: '8', label: '道 Gate', sub: '逐道驗收把關', accent: 'sage' },
      ]}
      ctas={[
        { href: '/contact/', label: '預約諮詢', variant: 'clay' },
        { href: '/solutions/', label: '了解解決方案', variant: 'ghost' },
      ]}
    />
  </Fragment>

  <!-- 01 使命與定位 -->
  <section class="section" id="mission" aria-labelledby="heading-01">
    <SectionHeader index="01" zh="使命與定位" en="MISSION & POSITIONING" />
    <div class="prose reveal">
      <p>
        顯藝科技的定位不是設備供應商，而是晶圓廠的 IT/OT+AI
        全棧系統整合商。我們直接為高量產晶圓廠承擔從架構設計、軟硬體選型、現場實施到持續運維的全程責任，以明確
        SLA 保障交付品質，不以期望管理替代工程驗證。
      </p>
      <p>
        FAB300 為我們的參考建置：以 NVIDIA GB300 NVL72 為算力底座，整合六層架構從 L1
        設備訊號到 L6 跨區域備援，覆蓋高量產晶圓廠全棧 IT/OT+AI 需求。同時引入 HGX B300
        推理節點與 Quantum-X800 800Gb/s XDR 高速 Fabric，確保算力生態符合 Blackwell Ultra
        世代的工程標準。
      </p>
      <p class="trust-line">
        競爭基準不是其他整合商，而是晶圓廠的自建團隊選項。我們承接的每項責任，都有 SLA
        與 Gate 驗收文件為憑，真實演練驗證，而非假設推算。
      </p>
    </div>
  </section>

  <!-- 02 我們交付什麼 -->
  <section class="section" id="what-we-deliver" aria-labelledby="heading-02">
    <SectionHeader index="02" zh="我們交付什麼" en="WHAT WE DELIVER" />
    <LayerStack />
    <div class="compliance-row reveal">
      <p class="compliance-label">合規基準 COMPLIANCE BASELINE</p>
      <ComplianceBadges />
    </div>
  </section>

  <!-- 03 治理與責任 -->
  <section class="section" id="governance" aria-labelledby="heading-03">
    <SectionHeader index="03" zh="治理與責任" en="GOVERNANCE & ACCOUNTABILITY" />
    <div class="governance-grid reveal">

      <article class="gov-pillar gov-pillar--sage">
        <span class="gov-pillar__tag gov-pillar__tag--sage">COVERAGE</span>
        <h3 class="gov-pillar__title">RACI 唯一 Accountable</h3>
        <p class="gov-pillar__body">
          每一議題指定唯一責任人（A），消除「多方負責=無人負責」的盲區。RACI
          矩陣在每個交付階段更新，確保每項決策皆有明確承擔者，廠方在任一時刻都可查詢責任歸屬。
        </p>
      </article>

      <article class="gov-pillar gov-pillar--sage">
        <span class="gov-pillar__tag gov-pillar__tag--sage">GOVERNANCE</span>
        <h3 class="gov-pillar__title">8 道 Gate 把關</h3>
        <p class="gov-pillar__body">
          逐道提交驗收文件，確認後才進入下一階段。Gate 1–2 機房土建與環境驗收、Gate 3–5
          GB300 NVL72 主交付與 MES 上線、Gate 6–7 高量產聯調與 DR 首輪演練、Gate 8
          全速量產上線。不跳關、不口頭確認。
        </p>
      </article>

      <article class="gov-pillar gov-pillar--sun">
        <span class="gov-pillar__tag gov-pillar__tag--sun">PERFORMANCE</span>
        <h3 class="gov-pillar__title">風險三級升級機制</h3>
        <p class="gov-pillar__body">
          綠色：例行追蹤，下次週會更新。黃色：48 小時內強制升級至項目委員會，啟動對策。紅色：即時上報廠方決策者，無緩衝、無等待。所有升級記錄存檔，列入下一 Gate
          驗收審查。
        </p>
      </article>

      <article class="gov-pillar gov-pillar--clay">
        <span class="gov-pillar__tag gov-pillar__tag--clay">RESILIENCE</span>
        <h3 class="gov-pillar__title">DR 季度實測演練</h3>
        <p class="gov-pillar__body">
          RTO ≤ 4hr 不是紙上承諾：每季執行一次完整 DR
          演練，模擬跨區域失效場景，記錄實際恢復時間。結果存檔並列入下季 Review，持續驗證韌性能力，確保承諾與現場一致。
        </p>
      </article>

    </div>
  </section>

  <!-- 04 交付節奏 -->
  <section class="section" id="delivery-rhythm" aria-labelledby="heading-04">
    <SectionHeader index="04" zh="交付節奏" en="DELIVERY RHYTHM" />
    <PhaseTimeline />
  </section>

  <!-- 05 為何信任我們 -->
  <section class="section" id="why-trust" aria-labelledby="heading-05">
    <SectionHeader index="05" zh="為何信任我們" en="LEADERSHIP & CREDENTIALS" />
    <div class="trust-grid reveal">

      <div class="trust-card">
        <p class="trust-card__en">METHODOLOGY</p>
        <h3 class="trust-card__title">有方法論，有文件，有演練</h3>
        <p class="trust-card__body">
          顯藝科技的交付方法論以 8 道 Gate
          為骨幹，每道 Gate 皆有完整驗收文件存底，杜絕口頭承諾。DR 演練結果存檔並循環改善，確保書面
          SLA 與現場韌性能力長期相符。
        </p>
      </div>

      <div class="trust-card">
        <p class="trust-card__en">NO LOCK-IN</p>
        <h3 class="trust-card__title">知識歸還，主權在廠方</h3>
        <p class="trust-card__body">
          交付完成後，所有架構決策文件、設定範本、操作 SOP 與 DR
          演練記錄，100% 移交給廠方。跨廠複製不依賴顯藝科技，知識資產永遠在您手中，第二座廠可直接套用同一範本。
        </p>
      </div>

      <div class="trust-card">
        <p class="trust-card__en">BASELINE</p>
        <h3 class="trust-card__title">以自建成本為競爭基準</h3>
        <p class="trust-card__body">
          顯藝科技的報價與自建人才成本、招募週期及技術風險直接比較。半導體廠 OT/IT
          全棧人才稀缺，自建能力所需時程通常超過兩個量產週期，且累積知識難以保留。
        </p>
      </div>

      <div class="trust-card">
        <p class="trust-card__en">ECOSYSTEM</p>
        <h3 class="trust-card__title">NVIDIA Blackwell Ultra 生態底座</h3>
        <p class="trust-card__body">
          FAB300 參考建置採用 NVIDIA GB300 NVL72（液冷）與 HGX B300
          推理節點為算力核心，搭配 Quantum-X800 800Gb/s XDR Fabric 及 NVMe
          Lakehouse，不採用過渡性方案，確保算力生態符合 GB300 世代工程標準。
        </p>
      </div>

    </div>
  </section>

  <!-- 06 關鍵數字 -->
  <section class="section" id="key-figures" aria-labelledby="heading-06">
    <SectionHeader index="06" zh="關鍵數字" en="KEY FIGURES" />
    <div class="stat-grid reveal">

      <article class="stat-block stat-block--sun">
        <span class="stat-block__rule" aria-hidden="true"></span>
        <p class="stat-block__value">GB300</p>
        <p class="stat-block__label">AI 算力底座</p>
        <p class="stat-block__sub">NVL72 液冷 · HGX B300 推理 · Quantum-X800 800Gb/s XDR Fabric</p>
        <span class="stat-block__accent-tag stat-block__accent-tag--sun">PERFORMANCE</span>
      </article>

      <article class="stat-block stat-block--sage">
        <span class="stat-block__rule" aria-hidden="true"></span>
        <p class="stat-block__value">4</p>
        <p class="stat-block__label">階段交付</p>
        <p class="stat-block__sub">建廠 → 裝機 → 試產 → 量產，M1–M22+，8 道 Gate 全程把關</p>
        <span class="stat-block__accent-tag stat-block__accent-tag--sage">COVERAGE</span>
      </article>

      <article class="stat-block stat-block--clay">
        <span class="stat-block__rule" aria-hidden="true"></span>
        <p class="stat-block__value">≤4hr</p>
        <p class="stat-block__label">DR RTO</p>
        <p class="stat-block__sub">RPO ≤ 15min · 溫備援跨區域 · 季度實測存檔</p>
        <span class="stat-block__accent-tag stat-block__accent-tag--clay">RESILIENCE</span>
      </article>

      <article class="stat-block stat-block--sage">
        <span class="stat-block__rule" aria-hidden="true"></span>
        <p class="stat-block__value">100%</p>
        <p class="stat-block__label">知識歸檔</p>
        <p class="stat-block__sub">交付後完整移交，可在每座新廠重複套用，無依賴鎖定</p>
        <span class="stat-block__accent-tag stat-block__accent-tag--sage">COVERAGE</span>
      </article>

    </div>
  </section>

  <!-- 07 ENGAGE -->
  <EngageCTA locale={locale} />
</PageLayout>

<script>
  import { revealOnEnter } from '../scripts/theme-motion';
  revealOnEnter('.reveal');
</script>

<style>
  /* ── Prose block (mission section) ── */
  .prose {
    max-width: 64ch;
    font-size: 1.1rem;
    line-height: 1.75;
  }
  .prose p {
    margin-bottom: 1.25rem;
  }
  .prose p:last-child {
    margin-bottom: 0;
  }
  .trust-line {
    font-family: var(--font-serif-tc);
    font-size: clamp(1.15rem, 2.5vw, 1.5rem);
    color: var(--sun);
    line-height: 1.55;
    border-left: 2px solid var(--sun);
    padding-left: 1.25rem;
    margin-top: 1.5rem;
  }

  /* ── Compliance row (below LayerStack) ── */
  .compliance-row {
    margin-top: clamp(2rem, 5vw, 3rem);
  }
  .compliance-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    color: var(--ink-muted);
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  /* ── Governance grid: 2×2 on desktop ── */
  .governance-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }
  @media (min-width: 768px) {
    .governance-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .gov-pillar {
    background: var(--surface);
    padding: clamp(1.5rem, 4vw, 2.5rem);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    position: relative;
  }
  /* Top-inset accent hairline per tri-accent color */
  .gov-pillar--sage { box-shadow: inset 0 3px 0 var(--sage); }
  .gov-pillar--sun  { box-shadow: inset 0 3px 0 var(--sun);  }
  .gov-pillar--clay { box-shadow: inset 0 3px 0 var(--clay); }

  .gov-pillar__tag {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    font-weight: 600;
    padding: 0.15em 0.55em;
    border-radius: 2px;
    border: 1px solid;
    align-self: flex-start;
  }
  .gov-pillar__tag--sage {
    color: var(--sage);
    border-color: color-mix(in srgb, var(--sage) 40%, transparent);
    background: color-mix(in srgb, var(--sage) 8%, transparent);
  }
  .gov-pillar__tag--sun {
    color: var(--sun);
    border-color: color-mix(in srgb, var(--sun) 40%, transparent);
    background: color-mix(in srgb, var(--sun) 8%, transparent);
  }
  .gov-pillar__tag--clay {
    color: var(--clay);
    border-color: color-mix(in srgb, var(--clay) 40%, transparent);
    background: color-mix(in srgb, var(--clay) 8%, transparent);
  }

  .gov-pillar__title {
    font-size: clamp(1.1rem, 2.5vw, 1.35rem);
    font-weight: 600;
    color: var(--ink);
    margin: 0;
  }
  .gov-pillar__body {
    font-size: 0.9rem;
    color: var(--ink-muted);
    line-height: 1.65;
    margin: 0;
    max-width: 52ch;
  }

  /* ── Trust grid: 2×2 ── */
  .trust-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 4vw, 2rem);
  }
  @media (min-width: 768px) {
    .trust-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .trust-card {
    border: 1px solid var(--border);
    padding: clamp(1.5rem, 4vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    background: var(--surface);
    position: relative;
  }
  /* Thin gold top-border on all trust cards */
  .trust-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--sun);
    opacity: 0.35;
  }

  .trust-card__en {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    color: var(--sun);
    margin: 0;
    text-transform: uppercase;
  }
  .trust-card__title {
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    font-weight: 600;
    color: var(--ink);
    margin: 0;
  }
  .trust-card__body {
    font-size: 0.9rem;
    color: var(--ink-muted);
    line-height: 1.65;
    margin: 0;
  }

  /* ── Stat grid: 4 columns (or 2×2 on tablet) ── */
  .stat-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }
  @media (min-width: 640px) {
    .stat-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .stat-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .stat-block {
    background: var(--surface);
    padding: clamp(2rem, 5vw, 3rem) clamp(1.5rem, 4vw, 2.5rem);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .stat-block__rule {
    display: block;
    width: 100%;
    height: 3px;
    margin-bottom: clamp(1.5rem, 4vw, 2.5rem);
  }
  .stat-block--clay .stat-block__rule { background: var(--clay); }
  .stat-block--sun  .stat-block__rule { background: var(--sun);  }
  .stat-block--sage .stat-block__rule { background: var(--sage); }

  .stat-block__value {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 8vw, 5rem);
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: -0.02em;
    margin: 0 0 0.5rem;
  }
  .stat-block--clay .stat-block__value { color: var(--clay); }
  .stat-block--sun  .stat-block__value { color: var(--sun);  }
  .stat-block--sage .stat-block__value { color: var(--sage); }

  .stat-block__label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    font-weight: 700;
    margin: 0 0 0.35rem;
  }
  .stat-block__sub {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink-muted);
    line-height: 1.55;
    margin: 0 0 0.75rem;
  }

  /* Accent semantic tag — text accompanies every color (DESIGN.md) */
  .stat-block__accent-tag {
    font-family: var(--font-mono);
    font-size: 0.60rem;
    letter-spacing: 0.14em;
    font-weight: 600;
    padding: 0.12em 0.45em;
    border-radius: 2px;
    border: 1px solid;
    align-self: flex-start;
    margin-top: auto;
  }
  .stat-block__accent-tag--clay {
    color: var(--clay);
    border-color: color-mix(in srgb, var(--clay) 40%, transparent);
    background: color-mix(in srgb, var(--clay) 8%, transparent);
  }
  .stat-block__accent-tag--sun {
    color: var(--sun);
    border-color: color-mix(in srgb, var(--sun) 40%, transparent);
    background: color-mix(in srgb, var(--sun) 8%, transparent);
  }
  .stat-block__accent-tag--sage {
    color: var(--sage);
    border-color: color-mix(in srgb, var(--sage) 40%, transparent);
    background: color-mix(in srgb, var(--sage) 8%, transparent);
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .trust-card,
    .gov-pillar,
    .stat-block {
      transition: none;
    }
  }
</style>
