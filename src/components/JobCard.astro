---
/**
 * JobCard — renders one roles entry (JD-00x).
 * Accepts a CollectionEntry<'roles'> and renders title, summary, tags,
 * and an email-apply affordance.
 *
 * Usage:
 *   const roles = await getCollection('roles');
 *   <JobCard role={roles[0]} />
 */
import type { CollectionEntry } from 'astro:content';

interface Props {
  role: CollectionEntry<'roles'>;
}

const { role } = Astro.props;
const { id, zhTitle, enTitle, functionTeam, level, priorityPhase, summary, tags } = role.data;

const applyHref = `mailto:hello@shinylogic.tech?subject=${encodeURIComponent(`Application — ${enTitle} (${id})`)}`;
---

<article class="job-card" aria-label={`${id} ${zhTitle}`}>
  <!-- Top meta row -->
  <div class="job-card__meta">
    <span class="job-card__id">{id}</span>
    <span class="job-card__team">{functionTeam}</span>
    <span class="job-card__phase">{priorityPhase}</span>
  </div>

  <!-- Title block -->
  <div class="job-card__titles">
    <h3 class="job-card__zh">{zhTitle}</h3>
    <p class="job-card__en">{enTitle}</p>
  </div>

  <!-- Level badge + summary -->
  <div class="job-card__body">
    <span class="job-card__level">{level}</span>
    <p class="job-card__summary">{summary}</p>
  </div>

  <!-- Tags -->
  <ul class="job-card__tags" aria-label="技能標籤">
    {tags.map((tag) => <li class="job-card__tag">{tag}</li>)}
  </ul>

  <!-- Apply affordance -->
  <a class="job-card__apply" href={applyHref}>
    <span class="job-card__apply-label">投遞履歷</span>
    <span class="job-card__apply-en" aria-hidden="true">APPLY →</span>
  </a>
</article>

<style>
  /* ── Card shell ── */
  .job-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: clamp(1.5rem, 4vw, 2rem);
    background: var(--surface);
    border: 1px solid var(--border);
    /* Sage inset stripe: coverage / governance accent */
    box-shadow: inset 0 2px 0 var(--sage);
    transition:
      border-color var(--dur-quick) var(--ease-out),
      box-shadow var(--dur-quick) var(--ease-out);
  }

  .job-card:hover {
    border-color: var(--border-strong);
    box-shadow:
      inset 0 2px 0 var(--sage),
      0 4px 24px rgba(0, 0, 0, 0.35);
  }

  /* ── Top meta: ID · team · phase ── */
  .job-card__meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .job-card__id {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    color: var(--sage);
    font-weight: 600;
  }

  .job-card__team,
  .job-card__phase {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    color: var(--ink-muted);
    padding: 0.15em 0.5em;
    border: 1px solid var(--border);
    border-radius: 2px;
  }

  /* ── Title block ── */
  .job-card__titles {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .job-card__zh {
    font-size: clamp(1.1rem, 3vw, 1.35rem);
    font-weight: 600;
    line-height: 1.2;
    color: var(--ink);
    margin: 0;
  }

  .job-card__en {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    color: var(--ink-muted);
    margin: 0;
  }

  /* ── Body: level + summary ── */
  .job-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .job-card__level {
    display: inline-flex;
    align-self: flex-start;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    font-weight: 600;
    padding: 0.15em 0.55em;
    border-radius: 2px;
    color: var(--sun);
    border: 1px solid color-mix(in srgb, var(--sun) 40%, transparent);
    background: color-mix(in srgb, var(--sun) 8%, transparent);
  }

  .job-card__summary {
    font-size: 0.88rem;
    line-height: 1.65;
    color: var(--ink-muted);
    margin: 0;
    max-width: 55ch;
  }

  /* ── Tags ── */
  .job-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .job-card__tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    padding: 0.2em 0.6em;
    border-radius: 2px;
    color: var(--ink-muted);
    border: 1px solid var(--border);
    background: var(--surface-raised);
  }

  /* ── Apply CTA ── */
  .job-card__apply {
    display: inline-flex;
    align-items: baseline;
    gap: 0.6rem;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
    text-decoration: none;
    color: var(--ink);
    transition: color var(--dur-quick) var(--ease-out);
  }

  .job-card__apply:hover {
    color: var(--sun);
  }

  .job-card__apply-label {
    font-size: 0.9rem;
    font-weight: 600;
  }

  .job-card__apply-en {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    color: var(--sun);
    transition: letter-spacing var(--dur-quick) var(--ease-out);
  }

  .job-card__apply:hover .job-card__apply-en {
    letter-spacing: 0.22em;
  }
</style>
