---
/**
 * ComplianceMatrix — five-standard compliance matrix for technology page §07 and methodology FIG.04.
 * Richer than ComplianceBadges: shows definition, domain, and scope for each standard.
 * Tri-accent: all five standards map to sage (coverage / governance / archive).
 * Summary statement sourced verbatim from content-inventory.md §07.
 */
import { getCollection } from 'astro:content';
import { t, localized, type Locale } from '../i18n/utils';

interface Props { locale?: Locale }
const { locale = 'zh-Hant' } = Astro.props;

const standards = (await getCollection('compliance')).sort(
  (a, b) => a.data.order - b.data.order,
);

// Domain → accent badge label (always uppercase English per design system).
// Lookup key uses base domain (zh-Hant) since that is the stable key in all JSON files.
const DOMAIN_LABEL: Record<string, string> = {
  'OT':       'OT COVERAGE',
  'OT / 設備': 'OT COVERAGE',
  'IT / 合規': 'GOVERNANCE',
  '合規':      'GOVERNANCE',
  'IT / OT':  'GOVERNANCE',
};
---

<section class="cm" aria-label={t('comp.c.cm.ariaLabel', locale)}>
  {/* Ambient HUD coordinate — decoration only */}
  <span class="cm__hud" aria-hidden="true">X:0720&nbsp;Y:GOV</span>

  <div class="cm__table-wrap" role="region" aria-label={t('comp.c.cm.tableAriaLabel', locale)}>
    <table class="cm__table">
      <caption class="cm__caption">
        {t('comp.c.cm.caption', locale)}
      </caption>

      <thead>
        <tr>
          <th class="cm__th cm__th--idx" scope="col" aria-label={t('comp.c.cm.col.idx.ariaLabel', locale)}>#</th>
          <th class="cm__th cm__th--name" scope="col">{t('comp.c.cm.col.standard', locale)}</th>
          <th class="cm__th cm__th--full" scope="col">{t('comp.c.cm.col.fullName', locale)}</th>
          <th class="cm__th cm__th--domain" scope="col">{t('comp.c.cm.col.domain', locale)}</th>
          <th class="cm__th cm__th--def" scope="col">{t('comp.c.cm.col.definition', locale)}</th>
        </tr>
      </thead>

      <tbody>
        {standards.map((s) => {
          const domainLabel = DOMAIN_LABEL[s.data.domain] ?? 'COVERAGE';
          const domainLocalized = String(localized(s.data, 'domain', locale));
          return (
            <tr class="cm__row">
              {/* Left accent rail rendered via ::before on <tr> */}
              <td class="cm__td cm__td--idx" aria-hidden="true">
                {String(s.data.order).padStart(2, '0')}
              </td>

              <td class="cm__td cm__td--name">
                <span class="cm__name">{s.data.name}</span>
              </td>

              <td class="cm__td cm__td--full">
                <span class="cm__full">{localized(s.data, 'fullName', locale)}</span>
              </td>

              <td class="cm__td cm__td--domain">
                {/* Sage accent badge with text label — required by tri-accent rule */}
                <span class="cm__domain-badge" aria-label={`${t('comp.c.cm.domainPrefix', locale)}${domainLocalized} · ${domainLabel}`}>
                  <span class="cm__domain-dot" aria-hidden="true" />
                  <span class="cm__domain-zh">{domainLocalized}</span>
                  <span class="cm__domain-label" aria-hidden="true">{domainLabel}</span>
                </span>
              </td>

              <td class="cm__td cm__td--def">
                <p class="cm__def">{localized(s.data, 'definition', locale)}</p>
              </td>
            </tr>
          );
        })}
      </tbody>

      <tfoot>
        <tr class="cm__footer-row">
          <td class="cm__footer-cell" colspan="5">
            <div class="cm__footer-inner">
              <span class="cm__footer-label" aria-hidden="true">COMPLIANCE NOTE</span>
              <span class="cm__footer-text">
                {t('comp.c.cm.footerNote', locale)}
              </span>
              {/* Sage accent marker — tri-accent system requires text label when color is used */}
              <span class="cm__footer-badge">
                <span class="cm__footer-dot" aria-hidden="true" />
                COVERAGE
              </span>
            </div>
          </td>
        </tr>
      </tfoot>
    </table>
  </div>
</section>

<style>
  /* ── Section wrapper ── */
  .cm {
    position: relative;
  }

  /* ── Ambient HUD coordinate (decoration only) ── */
  .cm__hud {
    position: absolute;
    top: 0;
    right: 0;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    color: var(--ink-faint);
    opacity: 0.45;
    pointer-events: none;
    user-select: none;
  }

  /* ── Scroll wrapper for narrow viewports ── */
  .cm__table-wrap {
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border: 1px solid var(--border-strong);
    border-radius: 2px;
  }

  /* ── Table base ── */
  .cm__table {
    width: 100%;
    min-width: 660px;
    border-collapse: collapse;
    background: var(--surface);
    table-layout: fixed;
  }

  /* Hidden caption for accessibility */
  .cm__caption {
    caption-side: top;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    color: var(--sage);
    text-align: left;
    padding: 0.9rem 1.25rem 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  /* ── Column widths ── */
  .cm__th--idx    { width: 3rem; }
  .cm__th--name   { width: 9rem; }
  .cm__th--full   { width: 16rem; }
  .cm__th--domain { width: 12rem; }
  .cm__th--def    { /* remaining */ }

  /* ── Header ── */
  .cm__th {
    padding: 0.65rem 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    font-weight: 600;
    color: var(--ink-muted);
    text-align: left;
    border-bottom: 1px solid var(--border-strong);
    white-space: nowrap;
    background: var(--surface);
  }
  .cm__th--idx { text-align: center; }

  /* ── Body rows ── */
  .cm__row {
    position: relative;
    border-bottom: 1px solid var(--border);
    transition:
      background var(--dur-instant) var(--ease-out);
  }
  .cm__row:last-child {
    border-bottom: none;
  }
  .cm__row:hover {
    background: var(--surface-raised);
  }

  /* Left accent rail — sage (coverage/governance) */
  .cm__row::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: transparent;
    transition: background var(--dur-quick) var(--ease-out);
  }
  .cm__row:hover::before {
    background: var(--sage);
  }

  /* ── Cells ── */
  .cm__td {
    padding: 1rem 1.1rem;
    vertical-align: top;
  }
  .cm__td--idx {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink-muted);
    letter-spacing: 0.08em;
    text-align: center;
    padding-top: 1.1rem;
  }

  /* Standard code — primary identifier */
  .cm__name {
    display: block;
    font-weight: 700;
    font-size: 0.92rem;
    color: var(--ink);
    line-height: 1.3;
  }

  /* Full name */
  .cm__full {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ink-muted);
    line-height: 1.5;
    letter-spacing: 0.02em;
  }

  /* Domain badge */
  .cm__domain-badge {
    display: inline-flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .cm__domain-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--sage);
    flex-shrink: 0;
  }
  .cm__domain-zh {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--sage);
    letter-spacing: 0.04em;
  }
  .cm__domain-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    color: var(--sage);
    font-weight: 600;
    padding: 0.12em 0.4em;
    border: 1px solid color-mix(in srgb, var(--sage) 30%, transparent);
    border-radius: 2px;
    background: color-mix(in srgb, var(--sage) 7%, transparent);
    display: inline-block;
    white-space: nowrap;
  }

  /* Definition text */
  .cm__def {
    margin: 0;
    font-size: 0.875rem;
    color: var(--ink-muted);
    line-height: 1.65;
  }

  /* ── Footer summary row ── */
  .cm__footer-row {
    background: var(--bg-deep);
  }
  .cm__footer-cell {
    padding: 0.85rem 1.1rem;
    border-top: 1px solid var(--border-strong);
  }
  .cm__footer-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.65rem;
  }
  .cm__footer-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    color: var(--ink-muted);
    flex-shrink: 0;
  }
  .cm__footer-text {
    font-size: 0.8rem;
    color: var(--ink-muted);
    line-height: 1.5;
    flex: 1 1 auto;
  }
  .cm__footer-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    font-weight: 600;
    color: var(--sage);
    padding: 0.15em 0.55em;
    border: 1px solid color-mix(in srgb, var(--sage) 35%, transparent);
    border-radius: 2px;
    background: color-mix(in srgb, var(--sage) 7%, transparent);
    flex-shrink: 0;
    white-space: nowrap;
  }
  .cm__footer-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--sage);
  }

  /* ── Responsive: stack domain badge on small screens ── */
  @media (max-width: 600px) {
    .cm__th--full,
    .cm__td--full {
      display: none;
    }
    .cm__th--domain { width: 8rem; }
  }

  /* ── Reduced motion: no transitions ── */
  @media (prefers-reduced-motion: reduce) {
    .cm__row,
    .cm__row::before {
      transition: none;
    }
  }
</style>
