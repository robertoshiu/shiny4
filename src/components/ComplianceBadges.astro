---
import { getCollection } from 'astro:content';
import { t, localized, type Locale } from '../i18n/utils';

interface Props { locale?: Locale }
const { locale = 'zh-Hant' } = Astro.props;

const items = (await getCollection('compliance')).sort((a, b) => a.data.order - b.data.order);
---

<ul class="compliance">
  {
    items.map((c, i) => {
      const detailId = `cmp-detail-${i}`;
      const hintId = `cmp-hint-${i}`;
      return (
        <li class="compliance__badge" data-hold-scan>
          <button
            type="button"
            class="compliance__trigger"
            data-hold-trigger
            aria-expanded="false"
            aria-controls={detailId}
            aria-describedby={hintId}
          >
            <span class="compliance__name">{c.data.name}</span>
            <span class="compliance__full">{localized(c.data, 'fullName', locale)}</span>
            <span class="compliance__cue" aria-hidden="true" />
            <svg
              class="compliance__arc"
              data-hold-arc
              viewBox="0 0 36 36"
              aria-hidden="true"
              focusable="false"
            >
              <circle class="compliance__arc-track" cx="18" cy="18" r="16" />
              <circle class="compliance__arc-fill"  cx="18" cy="18" r="16" />
            </svg>
          </button>
          <span id={hintId} class="sr-only">{t('holdScan.aria', locale)}</span>
          <div
            class="compliance__detail"
            id={detailId}
            data-hold-detail
            role="region"
            aria-label={String(localized(c.data, 'fullName', locale))}
          >
            <span class="compliance__domain">{localized(c.data, 'domain', locale)}</span>
            <p class="compliance__def">{localized(c.data, 'definition', locale)}</p>
          </div>
        </li>
      );
    })
  }
</ul>

<style>
  /* ── Badge list ── */
  .compliance {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  /* ── Badge outer container ── */
  .compliance__badge {
    border: 1px solid var(--border-strong);
    border-radius: 2px;
    background: transparent;
  }

  /* ── Trigger button — reset native + match old chip layout ── */
  .compliance__trigger {
    background: none;
    border: 0;
    padding: 0.75rem 2.75rem 0.75rem 1.1rem; /* right room for arc+cue */
    font: inherit;
    color: inherit;
    text-align: left;
    width: 100%;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    position: relative;
  }

  .compliance__trigger:focus-visible {
    outline: 2px solid var(--sun);
    outline-offset: 3px;
  }

  /* ── Badge chip text — unchanged from increment 2a ── */
  .compliance__name {
    font-weight: 700;
    color: var(--ink);
  }

  .compliance__full {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ink-muted);
  }

  /* ── +/− affordance ── */
  .compliance__cue {
    position: absolute;
    top: 50%;
    right: 1.65rem;
    transform: translateY(-50%);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--ink-muted);
    pointer-events: none;
    line-height: 1;
  }

  .compliance__cue::before {
    content: '+';
  }

  .compliance__badge.is-open .compliance__cue::before {
    content: '−';
  }

  /* ── Arc SVG ── */
  .compliance__arc {
    position: absolute;
    top: 0.5rem;
    right: 0.45rem;
    width: 18px;
    height: 18px;
    /* Rotate so arc starts at 12 o'clock */
    transform: rotate(-90deg);
    pointer-events: none;
    flex-shrink: 0;
  }

  .compliance__arc-track {
    fill: none;
    stroke: var(--border-strong);
    stroke-width: 2;
  }

  .compliance__arc-fill {
    fill: none;
    stroke: var(--sun);
    stroke-width: 2;
    stroke-linecap: round;
    /* Circumference of r=16 circle: 2π × 16 ≈ 100.53 */
    stroke-dasharray: 100.53;
    stroke-dashoffset: 100.53; /* starts empty; JS animates toward 0 */
  }

  /* Hide arc under reduced-motion (both media query and class) */
  @media (prefers-reduced-motion: reduce) {
    .compliance__arc {
      display: none;
    }
  }

  :global(html.reduced-motion) .compliance__arc {
    display: none;
  }

  /* ── Detail disclosure region ── */
  .compliance__detail {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    padding: 0 1.1rem 0.75rem;
    transition:
      max-height var(--dur-base) var(--ease-out),
      opacity var(--dur-quick) var(--ease-out);
  }

  .compliance__badge.is-open .compliance__detail {
    max-height: 16rem;
    opacity: 1;
    padding-top: 0.35rem;
  }

  /* Instant open under reduced-motion (no transition) */
  @media (prefers-reduced-motion: reduce) {
    .compliance__detail {
      transition: none;
    }
  }

  :global(html.reduced-motion) .compliance__detail {
    transition: none;
  }

  /* ── Domain label ── */
  .compliance__domain {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--sun);
    letter-spacing: 0.06em;
    margin-bottom: 0.35rem;
  }

  /* ── Definition text — --ink-muted, ≥ 13px (per design rule) ── */
  .compliance__def {
    margin: 0;
    font-size: 0.8125rem; /* 13px */
    color: var(--ink-muted);
    line-height: 1.6;
  }
</style>
