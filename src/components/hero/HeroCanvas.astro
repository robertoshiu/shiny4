<!--
  HeroCanvas — WebGL particle-system mount point.
  Sits above HeroPoster (z-index 1, starts opacity:0, fades in on first frame).
  initHero() is called after first paint via requestIdleCallback / setTimeout.
  Re-mounts on astro:page-load; destroyed on astro:before-swap / pagehide to
  release the WebGL context across View-Transition navigation.
  Under prefers-reduced-motion, initHero() returns a no-op early; poster stays.
-->
<canvas id="hero-canvas" class="hero-canvas" aria-hidden="true" tabindex="-1"></canvas>

<script>
  import { initHero } from '../../scripts/hero-webgl';
  import { prefersReducedMotion } from '../../scripts/theme-motion';

  let handle: { destroy(): void } | null = null;

  function teardown() {
    if (handle) { handle.destroy(); handle = null; }
  }

  function mount() {
    if (prefersReducedMotion()) return;
    if (handle) return; // already mounted on this page
    const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
    if (!canvas) return; // hero not present on this page

    const start = () => {
      if (handle) return;
      if (!canvas.isConnected) return; // navigated away before idle fired
      handle = initHero(canvas);
      requestAnimationFrame(() => canvas.classList.add('is-active'));
    };

    if ('requestIdleCallback' in window) {
      (window as unknown as { requestIdleCallback: (cb: () => void, o?: object) => void })
        .requestIdleCallback(start, { timeout: 1800 });
    } else {
      setTimeout(start, 160);
    }
  }

  // Re-mount on every page-load (initial + View Transition nav); release the
  // WebGL context before each swap and on real page exit.
  document.addEventListener('astro:page-load', mount);
  document.addEventListener('astro:before-swap', teardown);
  window.addEventListener('pagehide', teardown);
</script>

<style>
  .hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    opacity: 0;
    transition: opacity var(--dur-slow, 720ms) var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1));
    z-index: 1;
    /* Prevent any pointer capture that could interfere with page scroll */
    pointer-events: none;
  }
  .hero-canvas.is-active {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-canvas {
      display: none;
    }
  }
</style>
