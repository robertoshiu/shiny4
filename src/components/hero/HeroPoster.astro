---
import HudCoordinate from '../HudCoordinate.astro';
---

<!--
  HeroPoster — on-brand STATIC frame. Serves three roles:
  1. SSR / initial HTML frame (zero CLS — position:absolute, fills container)
  2. Reduced-motion permanent state (prefers-reduced-motion: reduce)
  3. No-WebGL fallback (canvas never becomes active)
  All elements are aria-hidden; no animation here (motion lives in HeroCanvas).
  Ring radii match the particle system's RING_RADII × 414px max-radius.
  Center: cx=720 cy=450 in the 1440×900 viewBox.
-->
<div class="hero-poster" aria-hidden="true">
  <svg
    class="hero-poster__svg"
    viewBox="0 0 1440 900"
    preserveAspectRatio="xMidYMid slice"
    role="presentation"
    focusable="false"
  >
    <defs>
      <!-- ── Bloom: gold core → clay mid → espresso edge ── -->
      <radialGradient id="hp-bloom" cx="50%" cy="50%" r="62%">
        <stop offset="0%"   stop-color="#E9C46A" stop-opacity="0.22"/>
        <stop offset="38%"  stop-color="#E07A5F" stop-opacity="0.16"/>
        <stop offset="80%"  stop-color="#14100D" stop-opacity="0.05"/>
        <stop offset="100%" stop-color="#14100D" stop-opacity="0"/>
      </radialGradient>

      <!-- ── Dot-matrix tile ── -->
      <pattern id="hp-dots" width="27" height="27" patternUnits="userSpaceOnUse">
        <circle cx="2" cy="2" r="1.6" fill="#E9C46A" fill-opacity="0.26"/>
      </pattern>

      <!-- ── Diagonal fade mask: dense bottom-left, sparse top-right ── -->
      <!-- SVG y=0 is top, so bottom-left = x1="0%" y1="100%"          -->
      <linearGradient id="hp-dot-fade" x1="0%" y1="100%" x2="100%" y2="0%">
        <stop offset="0%"   stop-color="white" stop-opacity="0.92"/>
        <stop offset="60%"  stop-color="white" stop-opacity="0.35"/>
        <stop offset="100%" stop-color="white" stop-opacity="0.08"/>
      </linearGradient>
      <mask id="hp-dot-mask">
        <rect width="1440" height="900" fill="url(#hp-dot-fade)"/>
      </mask>

      <!-- ── Ring glow filter (static; no perf budget concern here) ── -->
      <filter id="hp-ring-glow" x="-14%" y="-14%" width="128%" height="128%">
        <feGaussianBlur stdDeviation="2.2" result="blur"/>
        <feMerge>
          <feMergeNode in="blur"/>
          <feMergeNode in="SourceGraphic"/>
        </feMerge>
      </filter>

      <!-- ── Subtle outer-ring radial glow ── -->
      <filter id="hp-outer-glow" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="4" result="blur"/>
        <feMerge>
          <feMergeNode in="blur"/>
          <feMergeNode in="SourceGraphic"/>
        </feMerge>
      </filter>
    </defs>

    <!-- ── Background ──────────────────────────────────────────────────────── -->
    <rect width="1440" height="900" fill="#14100D"/>

    <!-- ── Ember dot-matrix ────────────────────────────────────────────────── -->
    <rect width="1440" height="900" fill="url(#hp-dots)" mask="url(#hp-dot-mask)"/>

    <!-- ── Giant faint numeral "01": awwwards editorial texture ──────────── -->
    <!-- Fraunces 900 weight; 5% opacity so it reads as texture, not content  -->
    <text
      x="790" y="650"
      font-family="'Fraunces', 'Noto Serif TC', serif"
      font-size="520"
      font-weight="900"
      font-style="normal"
      text-anchor="middle"
      fill="#E9C46A"
      fill-opacity="0.038"
      letter-spacing="-0.04em"
      aria-hidden="true"
    >01</text>

    <!-- ── Ambient radial axis lines (4 cardinal + 4 diagonal) ───────────── -->
    <!-- Cardinal lines: very faint horizontal + vertical cross -->
    <g stroke="#E9C46A" stroke-opacity="0.028" stroke-width="0.6">
      <!-- Horizontal axis -->
      <line x1="310" y1="450" x2="1130" y2="450"/>
      <!-- Vertical axis -->
      <line x1="720" y1="42"  x2="720"  y2="858"/>
    </g>
    <!-- Diagonal lines: even fainter -->
    <g stroke="#E9C46A" stroke-opacity="0.018" stroke-width="0.5">
      <!-- NE diagonal: 45° -->
      <line x1="430" y1="740" x2="1010" y2="160"/>
      <!-- NW diagonal: 135° -->
      <line x1="1010" y1="740" x2="430" y2="160"/>
    </g>

    <!-- ── Central ember bloom ─────────────────────────────────────────────── -->
    <circle cx="720" cy="450" r="400" fill="url(#hp-bloom)"/>

    <!-- ── Diffraction rings ───────────────────────────────────────────────── -->
    <!-- Radii match RING_RADII × 414px:
         [0.11, 0.20, 0.30, 0.41, 0.53, 0.65, 0.78, 0.93] × 414
         = [46, 83, 124, 170, 219, 269, 323, 385] px
         Opacity ramp: peaks at mid-annulus (rings 3-4), fades at extremes.
         Color: inner rings gold, outer clay — mirrors particle colour gradient. -->
    <g fill="none" filter="url(#hp-ring-glow)">
      <!-- r0: 46px — innermost, faint gold -->
      <circle cx="720" cy="450" r="46"  stroke="#E9C46A" stroke-opacity="0.10" stroke-width="0.6"/>
      <!-- r1: 83px -->
      <circle cx="720" cy="450" r="83"  stroke="#E9C46A" stroke-opacity="0.18" stroke-width="0.8"/>
      <!-- r2: 124px -->
      <circle cx="720" cy="450" r="124" stroke="#E9C46A" stroke-opacity="0.26" stroke-width="1.0"/>
      <!-- r3: 170px — peak inner -->
      <circle cx="720" cy="450" r="170" stroke="#E9C46A" stroke-opacity="0.32" stroke-width="1.3"/>
      <!-- r4: 219px — peak outer -->
      <circle cx="720" cy="450" r="219" stroke="#E07A5F" stroke-opacity="0.27" stroke-width="1.3"/>
      <!-- r5: 269px -->
      <circle cx="720" cy="450" r="269" stroke="#E07A5F" stroke-opacity="0.18" stroke-width="1.0"/>
      <!-- r6: 323px -->
      <circle cx="720" cy="450" r="323" stroke="#E07A5F" stroke-opacity="0.10" stroke-width="0.8"/>
      <!-- r7: 385px — outermost, very faint clay -->
      <circle cx="720" cy="450" r="385" stroke="#E07A5F" stroke-opacity="0.05" stroke-width="0.6"/>
    </g>

    <!-- ── Angle tick marks on two outer rings ─────────────────────────────── -->
    <!-- Cardinal ticks on r6 (323px): short radial lines at N/E/S/W           -->
    <g stroke="#E9C46A" stroke-opacity="0.20" stroke-width="0.7">
      <!-- North (720, 450-323=127) -->
      <line x1="720" y1="121" x2="720" y2="133"/>
      <!-- East (720+323=1043, 450) -->
      <line x1="1037" y1="450" x2="1049" y2="450"/>
      <!-- South (720, 450+323=773) -->
      <line x1="720" y1="767" x2="720" y2="779"/>
      <!-- West (720-323=397, 450) -->
      <line x1="391" y1="450" x2="403" y2="450"/>
    </g>
    <!-- Fine 45° ticks on r5 (269px): smaller marks -->
    <g stroke="#E9C46A" stroke-opacity="0.12" stroke-width="0.5">
      <!-- NE 45°: (720+269*cos45, 450-269*sin45) = (720+190, 450-190) = (910, 260) -->
      <line x1="906" y1="256" x2="914" y2="264"/>
      <!-- NW 135°: (720-190, 260) = (530, 260) -->
      <line x1="526" y1="256" x2="534" y2="264"/>
      <!-- SE 315°: (910, 640) -->
      <line x1="906" y1="636" x2="914" y2="644"/>
      <!-- SW 225°: (530, 640) -->
      <line x1="526" y1="636" x2="534" y2="644"/>
    </g>

    <!-- ── Centre reticle ─────────────────────────────────────────────────── -->
    <g stroke="#E9C46A" stroke-opacity="0.40" stroke-width="0.7" fill="none">
      <!-- Crosshair arms (gap at centre for readability) -->
      <line x1="704" y1="450" x2="716" y2="450"/>
      <line x1="724" y1="450" x2="736" y2="450"/>
      <line x1="720" y1="434" x2="720" y2="446"/>
      <line x1="720" y1="454" x2="720" y2="466"/>
      <!-- Tiny centre ring -->
      <circle cx="720" cy="450" r="3.5" stroke-opacity="0.28"/>
    </g>

    <!-- ── HUD ring-radius labels at 3 o'clock ─────────────────────────────── -->
    <!-- Positioned just outside rings r3, r5, r7 on the right side             -->
    <g
      font-family="'Spline Sans Mono', 'Courier New', monospace"
      font-size="8.5"
      fill="#6E6157"
      fill-opacity="0.65"
      letter-spacing="0.06em"
    >
      <!-- r3 = 170px → x: 720+170+10 = 900 -->
      <text x="900" y="453">r:170</text>
      <!-- r5 = 269px → x: 720+269+10 = 999 -->
      <text x="999" y="453">r:269</text>
      <!-- r7 = 385px label at top since right edge is ~1105 (within 1440) -->
      <text x="1105" y="453">r:385</text>
    </g>

    <!-- ── Corner HUD bracket: top-left ─────────────────────────────────────── -->
    <g stroke="#6E6157" stroke-opacity="0.38" stroke-width="0.7" fill="none">
      <!-- L-bracket -->
      <path d="M52,92 L52,62 L82,62"/>
      <!-- Dot at corner -->
      <circle cx="52" cy="62" r="1.5" fill="#6E6157" fill-opacity="0.4" stroke="none"/>
    </g>
    <text
      x="88" y="68"
      font-family="'Spline Sans Mono', 'Courier New', monospace"
      font-size="8"
      fill="#6E6157"
      fill-opacity="0.55"
      letter-spacing="0.07em"
    >X:0000 Y:0000</text>

    <!-- ── Corner HUD bracket: top-right ─────────────────────────────────────── -->
    <g stroke="#6E6157" stroke-opacity="0.38" stroke-width="0.7" fill="none">
      <path d="M1388,92 L1388,62 L1358,62"/>
      <circle cx="1388" cy="62" r="1.5" fill="#6E6157" fill-opacity="0.4" stroke="none"/>
    </g>
    <text
      x="1260" y="68"
      font-family="'Spline Sans Mono', 'Courier New', monospace"
      font-size="8"
      fill="#6E6157"
      fill-opacity="0.55"
      letter-spacing="0.07em"
    >SYS:NOMINAL ▲</text>

    <!-- ── Bottom-right corner bracket ──────────────────────────────────────── -->
    <g stroke="#6E6157" stroke-opacity="0.28" stroke-width="0.6" fill="none">
      <path d="M1388,808 L1388,838 L1358,838"/>
      <circle cx="1388" cy="838" r="1.2" fill="#6E6157" fill-opacity="0.3" stroke="none"/>
    </g>
  </svg>

  <!-- HTML HUD overlays — positioned via CSS, outside the SVG coordinate space -->
  <span class="hero-poster__hud hero-poster__hud--bl">
    <HudCoordinate text="X:0720 Y:0450 [REC]" />
  </span>
  <span class="hero-poster__hud hero-poster__hud--br">
    <HudCoordinate text="SHINYLOGIC // SYS-v4" />
  </span>
</div>

<style>
  .hero-poster {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    background: var(--bg, #14100D);
  }
  .hero-poster__svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .hero-poster__hud {
    position: absolute;
    /* Prevent text selection on decorative HUD labels */
    user-select: none;
    pointer-events: none;
  }
  .hero-poster__hud--bl {
    left:   clamp(1rem, 4vw, 4rem);
    bottom: clamp(1rem, 3.5vw, 2.5rem);
  }
  .hero-poster__hud--br {
    right:  clamp(1rem, 4vw, 4rem);
    bottom: clamp(1rem, 3.5vw, 2.5rem);
  }
</style>
