---
import SectionHeader from './SectionHeader.astro';
import { t } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

interface Props {
  index?: string;
  locale?: Locale;
}
const { index = '07', locale = 'zh-Hant' } = Astro.props;

const pillars = [
  {
    accent: 'gold',
    code: 'TALENT',
    title: t('buildvsbuy.talent.title', locale),
    enSub: 'Talent Scarcity',
    metric: 'SLO ≥ 95%',
    metricLabel: t('buildvsbuy.talent.metricLabel', locale),
    body: t('buildvsbuy.talent.body', locale),
    baseline: t('buildvsbuy.talent.baseline', locale),
  },
  {
    accent: 'clay',
    code: 'SCHEDULE',
    title: t('buildvsbuy.schedule.title', locale),
    enSub: 'Schedule Risk',
    metric: 'RTO ≤ 4hr',
    metricLabel: t('buildvsbuy.schedule.metricLabel', locale),
    body: t('buildvsbuy.schedule.body', locale),
    baseline: t('buildvsbuy.schedule.baseline', locale),
  },
  {
    accent: 'sage',
    code: 'ARCHIVE',
    title: t('buildvsbuy.archive.title', locale),
    enSub: 'No Lock-In · Full Archive',
    metric: t('buildvsbuy.archive.metric', locale),
    metricLabel: t('buildvsbuy.archive.metricLabel', locale),
    body: t('buildvsbuy.archive.body', locale),
    baseline: t('buildvsbuy.archive.baseline', locale),
  },
];
---

<section class="bvb" aria-labelledby="heading-07">
  <div class="bvb__inner">
    <SectionHeader index={index} zh={t('buildvsbuy.heading', locale)} en="BUILD vs. BUY" />

    <p class="bvb__lead">
      {t('buildvsbuy.lead', locale)}
    </p>

    <div class="bvb__grid">
      {pillars.map((p) => (
        <article class={`bvb__card bvb__card--${p.accent}`}>
          <header class="bvb__card-head">
            <span class="bvb__code" aria-hidden="true">{p.code}</span>
            <span class={`bvb__metric bvb__metric--${p.accent}`}>{p.metric}</span>
            <span class="bvb__metric-label">{p.metricLabel}</span>
          </header>

          <h3 class="bvb__zh">{p.title}</h3>
          <p class="bvb__en" aria-hidden="true">{p.enSub}</p>

          <p class="bvb__body">{p.body}</p>

          <footer class="bvb__baseline">
            <span class="bvb__baseline-label" aria-label={t('buildvsbuy.baseline.ariaLabel', locale)}>vs.</span>
            <span class="bvb__baseline-text">{p.baseline}</span>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .bvb {
    padding: clamp(5.5rem, 13vw, 10rem) var(--gutter);
    background: var(--bg-deep);
  }

  .bvb__inner {
    max-width: var(--maxw);
    margin: 0 auto;
  }

  .bvb__lead {
    font-size: clamp(0.95rem, 2vw, 1.1rem);
    color: var(--ink-muted);
    line-height: 1.7;
    max-width: 56ch;
    margin: 0 0 clamp(2rem, 5vw, 3.5rem);
  }

  /* Grid */
  .bvb__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }

  @media (min-width: 768px) {
    .bvb__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Card */
  .bvb__card {
    padding: clamp(1.75rem, 4vw, 2.5rem);
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
  }

  /* Top accent rule */
  .bvb__card::before {
    content: '';
    display: block;
    width: 40px;
    height: 2px;
    margin-bottom: 1.5rem;
  }
  .bvb__card--gold::before  { background: var(--sun); }
  .bvb__card--clay::before  { background: var(--clay); }
  .bvb__card--sage::before  { background: var(--sage); }

  /* Card head */
  .bvb__card-head {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 1.25rem;
  }

  .bvb__code {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: var(--ink-muted); /* promoted from --ink-faint: 2.87:1 → ≥4.5:1 AA */
  }

  .bvb__metric {
    font-family: var(--font-mono);
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 500;
    line-height: 1.1;
  }
  .bvb__metric--gold { color: var(--sun); }
  .bvb__metric--clay { color: var(--clay); }
  .bvb__metric--sage { color: var(--sage); }

  .bvb__metric-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ink-muted);
    letter-spacing: 0.06em;
  }

  /* Headings */
  .bvb__zh {
    font-size: clamp(1.1rem, 2.5vw, 1.35rem);
    font-weight: 700;
    color: var(--ink);
    margin: 0 0 0.2rem;
    line-height: 1.3;
  }

  .bvb__en {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: var(--ink-muted); /* promoted from --ink-faint: 2.87:1 → ≥4.5:1 AA */
    margin: 0 0 1.25rem;
  }

  /* Body copy */
  .bvb__body {
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--ink-muted);
    flex: 1;
    margin: 0 0 1.5rem;
  }

  /* Baseline footer */
  .bvb__baseline {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    margin-top: auto;
  }

  .bvb__baseline-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--ink-muted); /* promoted from --ink-faint; has aria-label so must pass 4.5:1 */
    flex-shrink: 0;
  }

  .bvb__baseline-text {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--ink-muted);
    line-height: 1.4;
  }
</style>
