---
import SectionHeader from './SectionHeader.astro';

interface Props {
  index?: string;
}
const { index = '07' } = Astro.props;

const pillars = [
  {
    accent: 'gold',
    code: 'TALENT',
    zh: '人才稀缺',
    en: 'Talent Scarcity',
    metric: 'SLO ≥ 95%',
    metricLabel: '服務水準保證',
    body: '半導體資料工程師全球短缺。自建團隊平均需 9–14 個月才能招募到具備 EDA 域知識的工程師，期間系統無人維護，良率分析停擺。我們的專職團隊已到位，隨時可接手。',
    baseline: '自建團隊平均招募期：9–14 個月',
  },
  {
    accent: 'clay',
    code: 'SCHEDULE',
    zh: '排程風險',
    en: 'Schedule Risk',
    metric: 'RTO ≤ 4hr',
    metricLabel: '復原時間目標',
    body: '在地團隊遇到人員異動、假期或緊急插件時，排程必然滑移。我們的異地備援架構與 on-call SLA 確保任何一點故障都在 4 小時內恢復，不因單一人員去留影響交付。',
    baseline: '內部中斷平均延誤：+3–6 週',
  },
  {
    accent: 'sage',
    code: 'ARCHIVE',
    zh: '無鎖定且 100% 歸檔',
    en: 'No Lock-In · Full Archive',
    metric: '100% 歸檔',
    metricLabel: '合約結束後資料完整移交',
    body: '所有程式碼、流程文件與歷史資料以開放格式存入客戶控管的儲存庫。合約任何時間點可終止，無遷移費、無專有格式綁定。您的資料永遠屬於您。',
    baseline: '典型 SaaS 鎖定期：3–5 年',
  },
] as const;
---

<section class="bvb" aria-labelledby="heading-07">
  <div class="bvb__inner">
    <SectionHeader index={index} zh="為何外包勝過自建" en="BUILD vs. BUY" />

    <p class="bvb__lead">
      競爭基準：晶圓廠自有 IT 團隊。<br />
      以下三項結構性差距，說明為何 SHINYLOGIC 是更快、更低風險的選擇。
    </p>

    <div class="bvb__grid">
      {pillars.map((p) => (
        <article class={`bvb__card bvb__card--${p.accent}`}>
          <header class="bvb__card-head">
            <span class="bvb__code" aria-hidden="true">{p.code}</span>
            <span class={`bvb__metric bvb__metric--${p.accent}`}>{p.metric}</span>
            <span class="bvb__metric-label">{p.metricLabel}</span>
          </header>

          <h3 class="bvb__zh">{p.zh}</h3>
          <p class="bvb__en" aria-hidden="true">{p.en}</p>

          <p class="bvb__body">{p.body}</p>

          <footer class="bvb__baseline">
            <span class="bvb__baseline-label" aria-label="競爭基準">vs.</span>
            <span class="bvb__baseline-text">{p.baseline}</span>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .bvb {
    padding: clamp(4rem, 10vw, 7rem) var(--gutter);
    background: var(--bg-deep);
  }

  .bvb__inner {
    max-width: var(--maxw);
    margin: 0 auto;
  }

  .bvb__lead {
    font-size: clamp(0.95rem, 2vw, 1.1rem);
    color: var(--ink-muted);
    line-height: 1.7;
    max-width: 56ch;
    margin: 0 0 clamp(2rem, 5vw, 3.5rem);
  }

  /* Grid */
  .bvb__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  @media (min-width: 768px) {
    .bvb__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Card */
  .bvb__card {
    background: var(--surface);
    padding: clamp(1.75rem, 4vw, 2.5rem);
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
  }

  /* Top accent rule */
  .bvb__card::before {
    content: '';
    display: block;
    width: 40px;
    height: 2px;
    margin-bottom: 1.5rem;
  }
  .bvb__card--gold::before  { background: var(--sun); }
  .bvb__card--clay::before  { background: var(--clay); }
  .bvb__card--sage::before  { background: var(--sage); }

  /* Card head */
  .bvb__card-head {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 1.25rem;
  }

  .bvb__code {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: var(--ink-faint);
  }

  .bvb__metric {
    font-family: var(--font-mono);
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 500;
    line-height: 1.1;
  }
  .bvb__metric--gold { color: var(--sun); }
  .bvb__metric--clay { color: var(--clay); }
  .bvb__metric--sage { color: var(--sage); }

  .bvb__metric-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ink-muted);
    letter-spacing: 0.06em;
  }

  /* Headings */
  .bvb__zh {
    font-size: clamp(1.1rem, 2.5vw, 1.35rem);
    font-weight: 700;
    color: var(--ink);
    margin: 0 0 0.2rem;
    line-height: 1.3;
  }

  .bvb__en {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: var(--ink-faint);
    margin: 0 0 1.25rem;
  }

  /* Body copy */
  .bvb__body {
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--ink-muted);
    flex: 1;
    margin: 0 0 1.5rem;
  }

  /* Baseline footer */
  .bvb__baseline {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    margin-top: auto;
  }

  .bvb__baseline-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--ink-faint);
    flex-shrink: 0;
  }

  .bvb__baseline-text {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--ink-muted);
    line-height: 1.4;
  }
</style>
