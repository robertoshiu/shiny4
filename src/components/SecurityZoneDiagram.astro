---
/**
 * SecurityZoneDiagram
 * Three-zone OT/IT security architecture diagram per Technology page §05.
 * Zones: OT域 / IT-OT邊界 / IT域
 * Tri-accent: clay=OT resilience · sage=boundary governance · sun=IT service level
 * Compliance alignment (IEC 62443 / SEMI E187 / ISA-95 / 等保2.0三級 / 密評)
 * Decorative SVG shapes are aria-hidden; all labels are real DOM text.
 */
import { t, type Locale } from '../i18n/utils';

interface Props { locale?: Locale }
const { locale = 'zh-Hant' } = Astro.props;

const zones = [
  {
    id: 'ot',
    accent: 'clay' as const,
    badge: 'RESILIENCE',
    zh: 'OT 域',
    zhHans: 'OT 域',
    en: 'OT DOMAIN',
    std: 'IEC 62443 Zone 1',
    items: [
      { zh: 'OT 入侵偵測與資產可視化', zhHans: 'OT 入侵侦测与资产可视化', en: 'IDS · Asset Visibility' },
      { zh: 'SECS-GEM / OPC UA 監控', zhHans: 'SECS-GEM / OPC UA 监控', en: 'Protocol Monitoring' },
      { zh: '設備固件完整性驗證', zhHans: '设备固件完整性验证', en: 'Firmware Integrity' },
    ],
    compliance: ['IEC 62443', 'SEMI E187'],
  },
  {
    id: 'boundary',
    accent: 'sage' as const,
    badge: 'GOVERNANCE',
    zh: 'IT/OT 邊界',
    zhHans: 'IT/OT 边界',
    en: 'BOUNDARY · CONDUIT',
    std: 'IEC 62443 Conduit',
    items: [
      { zh: 'NGFW 下一代防火牆', zhHans: 'NGFW 下一代防火墙', en: 'Next-Gen Firewall' },
      { zh: 'ISA-95 L3/L4 分段', zhHans: 'ISA-95 L3/L4 分段', en: 'Layer Segmentation' },
      { zh: 'VLAN 隔離', zhHans: 'VLAN 隔离', en: 'VLAN Isolation' },
      { zh: '加密傳輸 TLS 1.3', zhHans: '加密传输 TLS 1.3', en: 'Encrypted Transport' },
    ],
    compliance: ['ISA-95', 'IEC 62443'],
  },
  {
    id: 'it',
    accent: 'sun' as const,
    badge: 'PERFORMANCE',
    zh: 'IT 域',
    zhHans: 'IT 域',
    en: 'IT DOMAIN',
    std: 'IEC 62443 Zone 2',
    items: [
      { zh: 'SIEM / SOAR 平台', zhHans: 'SIEM / SOAR 平台', en: 'Security Operations' },
      { zh: 'SOC 24×7', zhHans: 'SOC 24×7', en: 'Round-the-Clock SOC' },
      { zh: 'EDR / IAM / PAM', zhHans: 'EDR / IAM / PAM', en: 'Endpoint & Access' },
      { zh: '威脅情報訂閱', zhHans: '威胁情报订阅', en: 'Threat Intelligence' },
    ],
    compliance: ['等保2.0三級', '密評'],
  },
];

// Helper: pick the locale-appropriate label for a zone
const zoneLabel = (zone: typeof zones[number]) =>
  locale === 'en' ? zone.en : locale === 'zh-Hans' ? zone.zhHans : zone.zh;

// Helper: pick the locale-appropriate item primary text
const itemLabel = (item: { zh: string; zhHans: string; en: string }) =>
  locale === 'en' ? item.en : locale === 'zh-Hans' ? item.zhHans : item.zh;

const complianceMatrix = [
  {
    std: 'IEC 62443',
    desc: '工業控制系統安全 · Zone/Conduit/SL 模型',
    desc_en: 'Industrial Control Systems Security · Zone/Conduit/SL Model',
    'desc_zh-Hans': '工业控制系统安全 · Zone/Conduit/SL 模型',
    zones: ['ot', 'boundary'],
  },
  {
    std: 'SEMI E187',
    desc: '晶圓廠設備網路安全規範 · SECS-GEM 通訊安全',
    desc_en: 'Wafer Fab Equipment Cybersecurity Spec · SECS-GEM Communication Security',
    'desc_zh-Hans': '晶圆厂设备网络安全规范 · SECS-GEM 通信安全',
    zones: ['ot'],
  },
  {
    std: 'ISA-95',
    desc: 'L3↔L4 整合標準 · MES/ERP 資訊交換模型',
    desc_en: 'L3↔L4 Integration Standard · MES/ERP Information Exchange Model',
    'desc_zh-Hans': 'L3↔L4 整合标准 · MES/ERP 信息交换模型',
    zones: ['boundary'],
  },
  {
    std: '等保2.0三級',
    desc: '關鍵資訊基礎設施安全等級保護',
    desc_en: 'Critical Information Infrastructure Security Level Protection',
    'desc_zh-Hans': '关键信息基础设施安全等级保护',
    zones: ['it', 'boundary'],
  },
  {
    std: '密評',
    desc: '商用密碼算法（SM2/SM3/SM4）應用安全評估',
    desc_en: 'Commercial Cryptographic Algorithm (SM2/SM3/SM4) Application Security Evaluation',
    'desc_zh-Hans': '商用密码算法（SM2/SM3/SM4）应用安全评估',
    zones: ['it'],
  },
];

// Helper: pick locale-appropriate desc from complianceMatrix row
const cmDesc = (row: typeof complianceMatrix[number]) =>
  locale === 'en'
    ? row.desc_en
    : locale === 'zh-Hans'
    ? row['desc_zh-Hans']
    : row.desc;
---

<figure class="szd" aria-label={t('comp.c.szd.ariaLabel', locale)}>

  {/* ── Section label ── */}
  <div class="szd__heading" aria-hidden="true">
    <span class="szd__hud">X:0520 Y:SEC01</span>
    <span class="szd__sub-en">SECURITY ARCHITECTURE · IEC 62443</span>
  </div>

  {/* ── Main zone diagram ── */}
  <div class="szd__diagram" role="list" aria-label={t('comp.c.szd.zonesAriaLabel', locale)}>

    {zones.map((zone, i) => (
      <article
        class={`szd__zone szd__zone--${zone.accent}`}
        role="listitem"
        aria-label={locale === 'en' ? zone.en : `${zoneLabel(zone)} ${zone.en}`}
      >

        {/* Decorative background SVG — aria-hidden */}
        <svg
          class="szd__zone-deco"
          viewBox="0 0 200 240"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          focusable="false"
        >
          {/* Faint dot-grid */}
          {[2,22,42,62,82,102,122,142,162,182,202,222].map(y =>
            [16,40,64,88,112,136,160,184].map(x => (
              <circle cx={x} cy={y} r="1" class={`szd__dot szd__dot--${zone.accent}`} />
            ))
          )}
          {/* Corner bracket top-left */}
          <path d="M8 8 L8 24 M8 8 L24 8" class={`szd__bracket szd__bracket--${zone.accent}`} />
          {/* Corner bracket bottom-right */}
          <path d="M192 232 L192 216 M192 232 L176 232" class={`szd__bracket szd__bracket--${zone.accent}`} />
          {/* IEC 62443 zone label decorative arc */}
          {zone.id === 'boundary' && (
            <path
              d="M100 20 A80 80 0 0 1 180 100"
              class="szd__arc"
            />
          )}
        </svg>

        {/* Zone header */}
        <header class="szd__zone-header">
          <div class="szd__zone-meta">
            <span class={`szd__zone-badge szd__zone-badge--${zone.accent}`}>
              {zone.badge}
            </span>
            <span class="szd__zone-std">{zone.std}</span>
          </div>
          <h3 class="szd__zone-zh">{zoneLabel(zone)}</h3>
          <p class="szd__zone-en-label">{zone.en}</p>
        </header>

        {/* Component list */}
        <ul class="szd__items" aria-label={`${zoneLabel(zone)} ${t('comp.c.szd.components', locale)}`}>
          {zone.items.map(item => (
            <li class="szd__item">
              <span class={`szd__item-dot szd__item-dot--${zone.accent}`} aria-hidden="true" />
              <span class="szd__item-body">
                <span class="szd__item-zh">{itemLabel(item)}</span>
                <span class="szd__item-en">{item.en}</span>
              </span>
            </li>
          ))}
        </ul>

        {/* Compliance chips for this zone */}
        <footer class="szd__zone-footer">
          {zone.compliance.map(std => (
            <span class={`szd__chip szd__chip--${zone.accent}`}>{std}</span>
          ))}
        </footer>

        {/* Flow connector (between zones, decorative) */}
        {i < zones.length - 1 && (
          <div class="szd__flow" aria-hidden="true">
            <svg viewBox="0 0 24 48" xmlns="http://www.w3.org/2000/svg" focusable="false">
              <line x1="12" y1="4" x2="12" y2="44" class="szd__flow-line" />
              <polyline points="8,38 12,44 16,38" class="szd__flow-arrow" />
            </svg>
          </div>
        )}
      </article>
    ))}

  </div>

  {/* ── Compliance alignment matrix ── */}
  <div class="szd__compliance" aria-label={t('comp.c.szd.complianceAriaLabel', locale)}>
    <p class="szd__compliance-heading" aria-hidden="true">
      <span class="szd__compliance-label">COMPLIANCE ALIGNMENT</span>
      <span class="szd__compliance-note">{t('comp.c.szd.complianceNote', locale)}</span>
    </p>
    <ul class="szd__matrix" role="list">
      {complianceMatrix.map(row => (
        <li class="szd__matrix-row" role="listitem">
          <span class="szd__matrix-std">{row.std}</span>
          <span class="szd__matrix-desc">{cmDesc(row)}</span>
          <span class="szd__matrix-zones" aria-label="applicable zones">
            {row.zones.map(z => {
              const zone = zones.find(zn => zn.id === z)!;
              return (
                <span class={`szd__matrix-zone szd__matrix-zone--${zone.accent}`}>
                  {zoneLabel(zone)}
                </span>
              );
            })}
          </span>
        </li>
      ))}
    </ul>
  </div>

</figure>

<style>
  /* ── Figure wrapper ── */
  .szd {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* ── Section label strip ── */
  .szd__heading {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .szd__hud {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    color: var(--ink-faint);
  }
  .szd__sub-en {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    color: var(--sun);
    text-transform: uppercase;
  }

  /* ── Zone grid ── */
  .szd__diagram {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border: 1px solid var(--border-strong);
    background: var(--border);
  }
  @media (min-width: 768px) {
    .szd__diagram {
      grid-template-columns: 1fr 0.85fr 1fr;
    }
  }

  /* ── Zone article ── */
  .szd__zone {
    position: relative;
    background: var(--surface);
    padding: clamp(1.5rem, 3.5vw, 2.25rem);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    overflow: hidden;
    /* Mobile: border-bottom separates rows */
    border-bottom: 1px solid var(--border);
  }
  .szd__zone:last-child {
    border-bottom: none;
  }
  @media (min-width: 768px) {
    .szd__zone {
      border-bottom: none;
      border-right: 1px solid var(--border);
    }
    .szd__zone:last-child {
      border-right: none;
    }
  }

  /* Top accent stripe */
  .szd__zone--clay  { box-shadow: inset 0 3px 0 var(--clay); }
  .szd__zone--sage  { box-shadow: inset 0 3px 0 var(--sage); }
  .szd__zone--sun   { box-shadow: inset 0 3px 0 var(--sun);  }

  /* Boundary zone gets a subtler raised bg */
  .szd__zone--sage {
    background: var(--surface-raised);
  }

  /* ── Decorative SVG background ── */
  .szd__zone-deco {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    user-select: none;
  }

  .szd__dot--clay  { fill: var(--clay);  opacity: 0.06; }
  .szd__dot--sage  { fill: var(--sage);  opacity: 0.07; }
  .szd__dot--sun   { fill: var(--sun);   opacity: 0.06; }

  .szd__bracket--clay  { stroke: var(--clay);  stroke-width: 1; fill: none; opacity: 0.25; }
  .szd__bracket--sage  { stroke: var(--sage);  stroke-width: 1; fill: none; opacity: 0.28; }
  .szd__bracket--sun   { stroke: var(--sun);   stroke-width: 1; fill: none; opacity: 0.25; }

  .szd__arc {
    stroke: var(--sage);
    stroke-width: 0.5;
    fill: none;
    opacity: 0.18;
    stroke-dasharray: 4 3;
  }

  /* ── Zone header ── */
  .szd__zone-header {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .szd__zone-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .szd__zone-badge {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.15em;
    font-weight: 600;
    padding: 0.15em 0.5em;
    border-radius: 2px;
    border: 1px solid;
  }
  .szd__zone-badge--clay {
    color: var(--clay);
    border-color: color-mix(in srgb, var(--clay) 40%, transparent);
    background: color-mix(in srgb, var(--clay) 8%, transparent);
  }
  .szd__zone-badge--sage {
    color: var(--sage);
    border-color: color-mix(in srgb, var(--sage) 40%, transparent);
    background: color-mix(in srgb, var(--sage) 8%, transparent);
  }
  .szd__zone-badge--sun {
    color: var(--sun);
    border-color: color-mix(in srgb, var(--sun) 40%, transparent);
    background: color-mix(in srgb, var(--sun) 8%, transparent);
  }

  .szd__zone-std {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
  }

  .szd__zone-zh {
    font-size: clamp(1.3rem, 3.5vw, 1.8rem);
    font-weight: 600;
    color: var(--ink);
    line-height: 1.15;
    margin: 0;
  }

  .szd__zone-en-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    color: var(--ink-muted);
    margin: 0;
  }

  /* ── Component item list ── */
  .szd__items {
    position: relative;
    z-index: 1;
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    flex: 1;
  }

  .szd__item {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
  }

  .szd__item-dot {
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    margin-top: 0.35em;
  }
  .szd__item-dot--clay { background: var(--clay); opacity: 0.8; }
  .szd__item-dot--sage { background: var(--sage); opacity: 0.8; }
  .szd__item-dot--sun  { background: var(--sun);  opacity: 0.8; }

  .szd__item-body {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .szd__item-zh {
    font-size: 0.88rem;
    color: var(--ink);
    line-height: 1.35;
  }

  .szd__item-en {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.07em;
    color: var(--ink-faint);
  }

  /* ── Zone footer chips ── */
  .szd__zone-footer {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
  }

  .szd__chip {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    padding: 0.2em 0.55em;
    border-radius: 2px;
    background: var(--bg-deep);
    border: 1px solid var(--border);
    color: var(--ink-muted);
  }

  /* ── Flow connector (mobile: bottom arrow; desktop: hidden — columns speak for themselves) ── */
  .szd__flow {
    display: flex;
    justify-content: center;
    padding-bottom: 0.5rem;
  }
  .szd__flow svg {
    width: 24px;
    height: 48px;
  }
  .szd__flow-line {
    stroke: var(--border-strong);
    stroke-width: 1;
  }
  .szd__flow-arrow {
    stroke: var(--border-strong);
    stroke-width: 1;
    fill: none;
  }
  @media (min-width: 768px) {
    .szd__flow {
      display: none;
    }
  }

  /* ── Compliance alignment matrix ── */
  .szd__compliance {
    border: 1px solid var(--border-strong);
    background: var(--bg-deep);
  }

  .szd__compliance-heading {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 0.9rem 1.25rem;
    border-bottom: 1px solid var(--border);
    margin: 0;
  }

  .szd__compliance-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    color: var(--sage);
    font-weight: 600;
  }

  .szd__compliance-note {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    color: var(--ink-faint);
  }

  .szd__matrix {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .szd__matrix-row {
    display: grid;
    grid-template-columns: 8rem 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid var(--border);
    transition: background var(--dur-instant) var(--ease-out);
  }
  .szd__matrix-row:last-child {
    border-bottom: none;
  }
  .szd__matrix-row:hover {
    background: var(--surface);
  }
  @media (max-width: 600px) {
    .szd__matrix-row {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }
  }

  .szd__matrix-std {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--ink);
    white-space: nowrap;
  }

  .szd__matrix-desc {
    font-size: 0.82rem;
    color: var(--ink-muted);
    line-height: 1.45;
  }

  .szd__matrix-zones {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  @media (max-width: 600px) {
    .szd__matrix-zones {
      justify-content: flex-start;
    }
  }

  .szd__matrix-zone {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    padding: 0.2em 0.5em;
    border-radius: 2px;
    white-space: nowrap;
  }
  .szd__matrix-zone--clay {
    color: var(--clay);
    background: color-mix(in srgb, var(--clay) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--clay) 30%, transparent);
  }
  .szd__matrix-zone--sage {
    color: var(--sage);
    background: color-mix(in srgb, var(--sage) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--sage) 30%, transparent);
  }
  .szd__matrix-zone--sun {
    color: var(--sun);
    background: color-mix(in srgb, var(--sun) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--sun) 30%, transparent);
  }

  /* ── Reduced-motion: strip transitions ── */
  @media (prefers-reduced-motion: reduce) {
    .szd__matrix-row {
      transition: none;
    }
  }
</style>
