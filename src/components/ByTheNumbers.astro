---
import { getCollection } from 'astro:content';

const PICK = new Set(['DR.01', 'SLO.03', 'KNW.06']);
const metrics = (await getCollection('slas'))
  .filter((s) => PICK.has(s.data.code))
  .sort((a, b) => a.data.order - b.data.order);
---

<div class="btn">
  {
    metrics.map((s) => (
      <article class={`btn__item btn__item--${s.data.accent} reveal`}>
        <span class="btn__rule" aria-hidden="true" />
        <p
          class="btn__value"
          data-to={s.data.value}
          data-prefix={s.data.prefix}
          data-suffix={s.data.suffix}
          aria-label={`${s.data.prefix}${s.data.value}${s.data.suffix}`}
        >
          {s.data.prefix}
          {s.data.value}
          {s.data.suffix}
        </p>
        <p class="btn__label">{s.data.label}</p>
        <p class="btn__sub">{s.data.sub}</p>
      </article>
    ))
  }
</div>

<script>
  import { countUp } from '../scripts/counter';
  const values = document.querySelectorAll<HTMLElement>('.btn__value[data-to]');
  const io = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;
        const el = entry.target as HTMLElement;
        countUp(el, {
          to: Number(el.dataset.to),
          prefix: el.dataset.prefix || '',
          suffix: el.dataset.suffix || '',
        });
        io.unobserve(el);
      }
    },
    { threshold: 0.3 },
  );
  values.forEach((v) => io.observe(v));
</script>

<style>
  .btn {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(3rem, 8vw, 5rem);
  }

  @media (min-width: 768px) {
    .btn {
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
    }
  }

  .btn__item {
    padding: clamp(2rem, 5vw, 3.5rem) clamp(1.5rem, 4vw, 3rem);
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 768px) {
    .btn__item + .btn__item {
      border-left: 1px solid var(--border);
    }
  }

  /* Accent rule — 3px stripe at top, full width */
  .btn__rule {
    display: block;
    width: 100%;
    height: 3px;
    margin-bottom: clamp(2rem, 5vw, 3rem);
  }

  .btn__item--clay .btn__rule {
    background: var(--clay);
  }
  .btn__item--gold .btn__rule {
    background: var(--sun);
  }
  .btn__item--sage .btn__rule {
    background: var(--sage);
  }

  /* Oversized Fraunces headline metric */
  .btn__value {
    font-family: var(--font-display);
    font-size: clamp(5rem, 13vw, 9rem);
    font-weight: 900;
    line-height: 0.88;
    letter-spacing: -0.02em;
    margin: 0 0 clamp(1.25rem, 3vw, 2rem);
  }

  .btn__item--clay .btn__value {
    color: var(--clay);
  }
  .btn__item--gold .btn__value {
    color: var(--sun);
  }
  .btn__item--sage .btn__value {
    color: var(--sage);
  }

  /* Label — mono, tracked, primary ink */
  .btn__label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    margin: 0 0 0.5rem;
  }

  /* Sub — mono, muted caption */
  .btn__sub {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--ink-muted);
    line-height: 1.6;
    margin: 0;
  }
</style>
