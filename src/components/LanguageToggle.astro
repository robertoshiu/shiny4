---
import { siblingUrl } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

// Compute sibling URLs from the actual current page path.
const pathname = Astro.url.pathname;
const segs = [
  { code: 'zh-Hant' as Locale, label: '繁', href: siblingUrl(pathname, 'zh-Hant') },
  { code: 'en' as Locale, label: 'EN', href: siblingUrl(pathname, 'en') },
  { code: 'zh-Hans' as Locale, label: '简', href: siblingUrl(pathname, 'zh-Hans') },
] as const;
---

<div class="lang-toggle" role="group" aria-label="語言選擇">
  {
    segs.map((s) =>
      s.code === locale ? (
        <span class="lang-toggle__seg is-active" aria-current="true">
          {s.label}
        </span>
      ) : (
        <a class="lang-toggle__seg" href={s.href} hreflang={s.code} lang={s.code}>
          {s.label}
        </a>
      ),
    )
  }
</div>

<style>
  .lang-toggle {
    display: inline-flex;
    border: 1px solid var(--border-strong);
    border-radius: 2px;
    overflow: hidden;
  }
  .lang-toggle__seg {
    min-width: 44px;
    min-height: 44px; /* WCAG 2.5.5 — was 36px, too small */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.4rem 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-decoration: none;
    color: var(--ink-muted);
  }
  .lang-toggle__seg.is-active {
    background: var(--surface-raised);
    color: var(--sun);
  }
  .lang-toggle__seg:not(.is-active):hover {
    color: var(--ink);
  }
  .lang-toggle__seg:focus-visible {
    /* Use inset box-shadow instead of outline — parent overflow:hidden clips
       child outlines in some browsers. Sun (#E9C46A) on dark bg ≈12:1;
       on surface-raised (#2a2018) ≈10.5:1. Both well above 3:1. */
    outline: none;
    box-shadow: inset 0 0 0 2px var(--sun);
  }
</style>
