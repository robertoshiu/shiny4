---
/**
 * DiagramGateProcess.astro — Four-Phase / Eight-Gate Delivery P&ID Process Flow.
 * Genre: P&ID orthogonal flat schematic (valves/pumps/sensors/interlock/gate bubbles).
 * Projection: orthogonal 2D — NOT exploded.
 * Dominant accent: SAGE (gate governance). SUN = P4 yield sensor. CLAY = rollback bypass.
 * Original generic schematic — original drawing.
 */
import DiagramField from './DiagramField.astro';
import { t, type Locale } from '../i18n/utils';

interface Props { locale: Locale }
const { locale } = Astro.props;

const legend = [
  { accent: 'sage' as const, labelKey: 'diagram.gate.legend.sage' },
  { accent: 'sun'  as const, labelKey: 'diagram.gate.legend.sun'  },
  { accent: 'clay' as const, labelKey: 'diagram.gate.legend.clay' },
];

// 8 gates are the BOM items
const bom = [
  { n: 1, labelKey: 'diagram.gate.bom.1', accent: 'sage' as const },
  { n: 2, labelKey: 'diagram.gate.bom.2', accent: 'sage' as const },
  { n: 3, labelKey: 'diagram.gate.bom.3', accent: 'sage' as const },
  { n: 4, labelKey: 'diagram.gate.bom.4', accent: 'sage' as const },
  { n: 5, labelKey: 'diagram.gate.bom.5', accent: 'sage' as const },
  { n: 6, labelKey: 'diagram.gate.bom.6', accent: 'sage' as const },
  { n: 7, labelKey: 'diagram.gate.bom.7', accent: 'sage' as const },
  { n: 8, labelKey: 'diagram.gate.bom.8', accent: 'sage' as const },
];

// ── Layout geometry ─────────────────────────────────────────────────────────
// Main process line: y=430, x=150→1290
const LINE_Y = 430;
const LINE_X1 = 150;
const LINE_X2 = 1290;

// Phase vessel centers (x) and half-widths
const PHASES: { x: number; key: string }[] = [
  { x: 280,  key: 'diagram.gate.phase.P1' },
  { x: 560,  key: 'diagram.gate.phase.P2' },
  { x: 850,  key: 'diagram.gate.phase.P3' },
  { x: 1130, key: 'diagram.gate.phase.P4' },
];
const PW = 75; // half-width of vessel rect
const PH = 60; // half-height

// 8 gate bubble x positions (on the line)
const GATES = [200, 370, 470, 650, 740, 980, 1060, 1220];

// Valve x positions (bowtie symbol, between phases)
const VALVE_X = [425, 710, 1005];

// Pump x position (circle+triangle at start)
const PUMP_X = 152;

// Sensor positions (drop below line)
const SENSORS: { x: number; accent?: 'sun' | 'sage'; label: string }[] = [
  { x: 560,  label: 'FT'  },
  { x: 1130, label: 'YLD', accent: 'sun' },
];

// Interlock bus (horizontal bar at y=650)
const IBUS_Y = 648;

// Sparse grid
const gridLines: { x1:number; y1:number; x2:number; y2:number }[] = [];
for (let x = 48; x < 1440; x += 96) gridLines.push({ x1:x, y1:0, x2:x, y2:900 });
for (let y = 48; y < 900;  y += 96) gridLines.push({ x1:0, y1:y, x2:1440, y2:y });
---

<DiagramField
  id="gate-process"
  locale={locale}
  figcaptionKey="diagram.gate.figcaption"
  legend={legend}
  bom={bom}
  dominantAccent="sage"
  viewBox="0 0 1440 900"
  numeral="01"
>
  <defs>
    <pattern id="dg-hatch45" patternUnits="userSpaceOnUse" width="7" height="7" patternTransform="rotate(45)">
      <line x1="0" y1="0" x2="0" y2="7" stroke="var(--ink-faint)" stroke-width="1" opacity="0.5"/>
    </pattern>
    {/* Arrow marker for flow direction */}
    <marker id="dg-arr" markerWidth="7" markerHeight="7" refX="3" refY="3.5" orient="auto">
      <path d="M 0 0 L 7 3.5 L 0 7 Z" fill="var(--sage)" opacity="0.7"/>
    </marker>
    <marker id="dg-arr-clay" markerWidth="7" markerHeight="7" refX="3" refY="3.5" orient="auto">
      <path d="M 0 0 L 7 3.5 L 0 7 Z" fill="var(--clay)" opacity="0.7"/>
    </marker>
  </defs>

  {/* Grid */}
  <g data-diagram-layer="grid" aria-hidden="true" class="dg-layer-mobile-hide">
    {gridLines.map(l => <line x1={l.x1} y1={l.y1} x2={l.x2} y2={l.y2} class="dg__grid-line" />)}
  </g>

  {/* Interlock bus (centerline style dash-dot) */}
  <g data-diagram-layer="centerlines" aria-hidden="true" class="dg-layer-mobile-hide">
    <path d={`M 185 ${IBUS_Y} L 1240 ${IBUS_Y}`} data-centerline class="dg__interlock-bus" />
    {/* Vertical interlock drops from each gate to bus */}
    {GATES.map(gx => (
      <path d={`M ${gx} ${LINE_Y + 18} L ${gx} ${IBUS_Y}`} data-centerline class="dg__centerline" />
    ))}
  </g>

  {/* ── Parts (all non-exploded, dx=0 dy=0) ── */}
  <g data-diagram-layer="parts">

    {/* Phase vessels (4 rects) — background context */}
    {PHASES.map(p => (
      <g>
        <rect x={p.x - PW} y={LINE_Y - PH} width={PW * 2} height={PH * 2} class="dg__unit" />
        <text x={p.x} y={LINE_Y - PH - 8} class="dg__tool-label" text-anchor="middle">
          {t(p.key, locale)}
        </text>
      </g>
    ))}

    {/* P3 vessel: half-section hatch on lower-left */}
    <rect x={PHASES[2].x - PW} y={LINE_Y} width={PW} height={PH} class="dg__tool-hatch" />

    {/* Pump at start (circle + triangle) */}
    <g data-part data-part-id="pump" data-ex-dx="0" data-ex-dy="0" transform="translate(0,0)">
      <circle cx={PUMP_X} cy={LINE_Y} r="14" class="dg__pump-circle" />
      <path d={`M ${PUMP_X - 6} ${LINE_Y - 9} L ${PUMP_X + 8} ${LINE_Y} L ${PUMP_X - 6} ${LINE_Y + 9} Z`} class="dg__pump-blade" />
    </g>

    {/* Valve symbols (bowtie) at 3 transition points */}
    {VALVE_X.map(vx => (
      <g data-part data-part-id={`valve-${vx}`} data-ex-dx="0" data-ex-dy="0" transform="translate(0,0)">
        {/* Bowtie: two triangles meeting at center */}
        <path d={`M ${vx - 10} ${LINE_Y - 10} L ${vx} ${LINE_Y} L ${vx - 10} ${LINE_Y + 10} Z`} class="dg__valve" />
        <path d={`M ${vx + 10} ${LINE_Y - 10} L ${vx} ${LINE_Y} L ${vx + 10} ${LINE_Y + 10} Z`} class="dg__valve" />
        {/* Stem */}
        <line x1={vx} y1={LINE_Y - 18} x2={vx} y2={LINE_Y - 10} class="dg__valve-stem" />
        <line x1={vx - 8} y1={LINE_Y - 18} x2={vx + 8} y2={LINE_Y - 18} class="dg__valve-stem" />
      </g>
    ))}

    {/* Sensors (instrument bubbles below line) */}
    {SENSORS.map(s => (
      <g data-part data-part-id={`sensor-${s.x}`} data-ex-dx="0" data-ex-dy="0" transform="translate(0,0)">
        <line x1={s.x} y1={LINE_Y + 18} x2={s.x} y2={LINE_Y + 42} class="dg__sensor-stem" />
        <circle cx={s.x} cy={LINE_Y + 56} r="14" class:list={['dg__instr', s.accent ? `dg__instr--${s.accent}` : '']} />
        <text x={s.x} y={LINE_Y + 60} class:list={['dg__tool-label', s.accent ? `dg__tool-label--${s.accent}` : '']} text-anchor="middle">{s.label}</text>
      </g>
    ))}

    {/* Interlock bus label */}
    <g data-part data-part-id="interlock-bus" data-ex-dx="0" data-ex-dy="0" transform="translate(0,0)">
      <rect x="185" y={IBUS_Y - 10} width="1055" height="20" class="dg__interlock-bar" />
      <text x="712" y={IBUS_Y + 4} class="dg__tool-label dg__tool-label--sage" text-anchor="middle">GOVERNANCE INTERLOCK BUS</text>
    </g>

    {/* CLAY rollback/bypass: P4→up→loop left→P1 */}
    <g data-part data-part-id="rollback-bypass" data-ex-dx="0" data-ex-dy="0" transform="translate(0,0)">
      {/* Clay dashed bypass valve mid-span */}
      <path d={`M ${PHASES[3].x} ${LINE_Y - PH} L ${PHASES[3].x} 260 L ${PHASES[0].x} 260 L ${PHASES[0].x} ${LINE_Y - PH}`}
            class="dg__flow-path dg__flow-path--clay" stroke-dasharray="8 4" stroke-width="2" fill="none" />
      {/* Bypass valve symbol */}
      <path d={`M 695 250 L 705 260 L 695 270 Z`} class="dg__valve dg__valve--clay" />
      <path d={`M 715 250 L 705 260 L 715 270 Z`} class="dg__valve dg__valve--clay" />
      <text x="705" y="242" class="dg__tool-label dg__tool-label--clay" text-anchor="middle">BYPASS</text>
    </g>

    {/* 8 Gate bubbles (the BOM items — ISA instrument circles) */}
    {GATES.map((gx, i) => (
      <g data-part data-part-id={`gate-${i+1}`} data-ex-dx="0" data-ex-dy="0" transform="translate(0,0)">
        {/* Gate bubble on the line */}
        <circle cx={gx} cy={LINE_Y} r="18" class="dg__gate-bubble" />
        <text x={gx} y={LINE_Y - 2} class="dg__tool-label dg__tool-label--sage" text-anchor="middle" font-size="11">G{i+1}</text>
        <text x={gx} y={LINE_Y + 10} class="dg__tool-label dg__tool-label--sage" text-anchor="middle" font-size="9">{i+1}</text>
        {/* Leader up to balloon */}
        <line x1={gx} y1={LINE_Y - 18} x2={gx} y2={LINE_Y - 55} class="dg__leader" />
        <circle cx={gx} cy={LINE_Y - 18} r="3" class="dg__leader-dot" />
        <circle cx={gx} cy={LINE_Y - 69} r="14" class="dg__balloon" />
        <text x={gx} y={LINE_Y - 65} class="dg__balloon-num" text-anchor="middle">{i+1}</text>
      </g>
    ))}

  </g>

  {/* ── Dimensions ── */}
  <g data-diagram-layer="dimensions" aria-hidden="true" class="dg-layer-mobile-hide">
    {/* SAGE: gate coverage span */}
    <line x1="185" y1="800" x2="1240" y2="800" class="dg__dim-line dg__dim-line--sage" />
    <line x1="185" y1="790" x2="185" y2="810" class="dg__dim-tick" />
    <line x1="1240" y1="790" x2="1240" y2="810" class="dg__dim-tick" />
    <text x="712" y="818" class="dg__dim-val dg__dim-val--sage" text-anchor="middle">8 / 8</text>
    <text x="712" y="832" class="dg__dim-caption dg__dim-caption--sage" text-anchor="middle">{t('diagram.gate.dim.sage.cap', locale)}</text>

    {/* SUN: P4 yield sensor */}
    <line x1="1090" y1="840" x2="1170" y2="840" class="dg__dim-line" />
    <line x1="1090" y1="832" x2="1090" y2="848" class="dg__dim-tick" />
    <line x1="1170" y1="832" x2="1170" y2="848" class="dg__dim-tick" />
    <text x="1130" y="856" class="dg__dim-val dg__dim-val--sun" text-anchor="middle">≥ 90%</text>
    <text x="1130" y="870" class="dg__dim-caption dg__dim-caption--sun" text-anchor="middle">{t('diagram.gate.dim.sun.cap', locale)}</text>

    {/* CLAY: bypass/rollback */}
    <line x1="660" y1="248" x2="750" y2="248" class="dg__dim-line dg__dim-line--clay" stroke-dasharray="6 3" />
    <text x="705" y="238" class="dg__dim-val dg__dim-val--clay" text-anchor="middle">≤ 4hr</text>

    {/* Neutral: schedule scale */}
    <line x1="185" y1="858" x2="1240" y2="858" class="dg__dim-line" />
    <text x="712" y="876" class="dg__dim-val" text-anchor="middle">M1–M22+</text>
  </g>

  {/* ── Sage flow: main process line (dominant accent) ── */}
  <g data-diagram-layer="flow">
    {/* Main process line segments (between gate bubbles) */}
    <path d={`M ${LINE_X1 + 14} ${LINE_Y} L ${GATES[0] - 18} ${LINE_Y}`} data-flow pathLength="1" class="dg__flow-path dg__flow-path--sage" marker-end="url(#dg-arr)" />
    <path d={`M ${GATES[0] + 18} ${LINE_Y} L ${GATES[1] - 18} ${LINE_Y}`} data-flow pathLength="1" class="dg__flow-path dg__flow-path--sage" />
    <path d={`M ${GATES[1] + 18} ${LINE_Y} L ${GATES[2] - 18} ${LINE_Y}`} data-flow pathLength="1" class="dg__flow-path dg__flow-path--sage" />
    <path d={`M ${GATES[2] + 18} ${LINE_Y} L ${GATES[3] - 18} ${LINE_Y}`} data-flow pathLength="1" class="dg__flow-path dg__flow-path--sage" />
    <path d={`M ${GATES[3] + 18} ${LINE_Y} L ${GATES[4] - 18} ${LINE_Y}`} data-flow pathLength="1" class="dg__flow-path dg__flow-path--sage" />
    <path d={`M ${GATES[4] + 18} ${LINE_Y} L ${GATES[5] - 18} ${LINE_Y}`} data-flow pathLength="1" class="dg__flow-path dg__flow-path--sage" />
    <path d={`M ${GATES[5] + 18} ${LINE_Y} L ${GATES[6] - 18} ${LINE_Y}`} data-flow pathLength="1" class="dg__flow-path dg__flow-path--sage" />
    <path d={`M ${GATES[6] + 18} ${LINE_Y} L ${GATES[7] - 18} ${LINE_Y}`} data-flow pathLength="1" class="dg__flow-path dg__flow-path--sage" />
    <path d={`M ${GATES[7] + 18} ${LINE_Y} L ${LINE_X2} ${LINE_Y}`} data-flow pathLength="1" class="dg__flow-path dg__flow-path--sage" marker-end="url(#dg-arr)" />
  </g>

  <text x="720" y="888" class="dg__disclaimer" text-anchor="middle" aria-hidden="true">{t('diagram.gate.disclaimer', locale)}</text>
</DiagramField>

<style>
  /* P&ID-specific symbol classes */
  :global(.dg__unit) {
    fill: color-mix(in srgb, var(--ink) 4%, transparent);
    stroke: var(--ink);
    stroke-width: 1.4;
  }
  :global(.dg__valve) {
    fill: color-mix(in srgb, var(--ink) 15%, transparent);
    stroke: var(--ink);
    stroke-width: 1.2;
  }
  :global(.dg__valve--clay) {
    fill: color-mix(in srgb, var(--clay) 15%, transparent);
    stroke: var(--clay);
    stroke-width: 1.2;
  }
  :global(.dg__valve-stem) {
    stroke: var(--ink);
    stroke-width: 1;
    fill: none;
    opacity: 0.7;
  }
  :global(.dg__pump-circle) {
    fill: color-mix(in srgb, var(--ink) 6%, transparent);
    stroke: var(--ink);
    stroke-width: 1.4;
  }
  :global(.dg__pump-blade) {
    fill: color-mix(in srgb, var(--ink) 20%, transparent);
    stroke: var(--ink);
    stroke-width: 0.8;
  }
  :global(.dg__gate-bubble) {
    fill: color-mix(in srgb, var(--sage) 12%, transparent);
    stroke: var(--sage);
    stroke-width: 1.4;
  }
  :global(.dg__instr) {
    fill: color-mix(in srgb, var(--ink) 6%, transparent);
    stroke: var(--ink-muted);
    stroke-width: 1;
  }
  :global(.dg__instr--sun) {
    fill: color-mix(in srgb, var(--sun) 12%, transparent);
    stroke: var(--sun);
    stroke-width: 1.4;
  }
  :global(.dg__sensor-stem) {
    stroke: var(--ink-faint);
    stroke-width: 0.75;
    fill: none;
    opacity: 0.7;
  }
  :global(.dg__interlock-bar) {
    fill: color-mix(in srgb, var(--sage) 6%, transparent);
    stroke: var(--sage);
    stroke-width: 1;
    opacity: 0.5;
  }
  :global(.dg__interlock-bus) {
    fill: none;
    stroke: var(--sage);
    stroke-width: 1.5;
    stroke-dasharray: 16 4 2 4;
    opacity: 0.5;
  }
</style>
