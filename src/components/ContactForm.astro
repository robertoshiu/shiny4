---
/**
 * ContactForm.astro
 *
 * Self-contained inquiry form for the Contact page (預約諮詢).
 * • 5 user fields + hidden honeypot
 * • Inquiry-type options loaded from the `inquiryTypes` content collection
 * • Client-side validation with per-field aria-describedby error hints
 * • aria-live success / error status region
 * • Falls back to mailto: if CONTACT_ENDPOINT is not configured
 */
import { getCollection } from 'astro:content';

const types = (await getCollection('inquiryTypes')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<div class="cf-wrap">
  <!-- Decorative HUD header ────────────────────────────────────── -->
  <div class="cf-hud" aria-hidden="true">
    <span class="cf-hud__coord">X:0901 Y:FORM</span>
    <span class="cf-hud__sep">·</span>
    <span class="cf-hud__label">INQUIRY FORM</span>
  </div>

  <form
    id="contact-form"
    class="contact-form"
    novalidate
    aria-label="諮詢表單"
  >
    <!-- ── Row 1: Name + Company (side-by-side on ≥640px) ── -->
    <div class="cf-row">
      <!-- Name ───────────────────────────────────────────────── -->
      <div class="cf-field">
        <label class="cf-label" for="cf-name">
          姓名
          <span class="cf-label__req" aria-hidden="true">*</span>
          <span class="cf-label__en">NAME</span>
        </label>
        <input
          class="cf-input"
          id="cf-name"
          name="name"
          type="text"
          autocomplete="name"
          aria-required="true"
          aria-describedby="cf-name-error"
          placeholder="王曉明"
        />
        <span
          id="cf-name-error"
          class="cf-error"
          data-error="name"
          aria-live="polite"
        ></span>
      </div>

      <!-- Company ─────────────────────────────────────────────── -->
      <div class="cf-field">
        <label class="cf-label" for="cf-company">
          公司
          <span class="cf-label__opt">（選填）</span>
          <span class="cf-label__en">COMPANY</span>
        </label>
        <input
          class="cf-input"
          id="cf-company"
          name="company"
          type="text"
          autocomplete="organization"
          placeholder="台積電、聯電…"
        />
      </div>
    </div>

    <!-- ── Email ─────────────────────────────────────────────── -->
    <div class="cf-field">
      <label class="cf-label" for="cf-email">
        電子郵件
        <span class="cf-label__req" aria-hidden="true">*</span>
        <span class="cf-label__en">EMAIL</span>
      </label>
      <input
        class="cf-input"
        id="cf-email"
        name="email"
        type="email"
        autocomplete="email"
        inputmode="email"
        aria-required="true"
        aria-describedby="cf-email-error"
        placeholder="you@company.com"
      />
      <span
        id="cf-email-error"
        class="cf-error"
        data-error="email"
        aria-live="polite"
      ></span>
    </div>

    <!-- ── Inquiry type ──────────────────────────────────────── -->
    <div class="cf-field">
      <label class="cf-label" for="cf-inquiry-type">
        諮詢類型
        <span class="cf-label__req" aria-hidden="true">*</span>
        <span class="cf-label__en">INQUIRY TYPE</span>
      </label>
      <div class="cf-select-wrap">
        <select
          class="cf-select"
          id="cf-inquiry-type"
          name="inquiryType"
          aria-required="true"
          aria-describedby="cf-inquiry-type-error"
        >
          <option value="">— 請選擇諮詢類型 —</option>
          {
            types.map((t) => (
              <option value={t.data.zhName}>
                {t.data.zhName} · {t.data.enLabel}
              </option>
            ))
          }
        </select>
        <span class="cf-select-arrow" aria-hidden="true">▾</span>
      </div>
      <span
        id="cf-inquiry-type-error"
        class="cf-error"
        data-error="inquiryType"
        aria-live="polite"
      ></span>
    </div>

    <!-- ── Message ───────────────────────────────────────────── -->
    <div class="cf-field">
      <label class="cf-label" for="cf-message">
        訊息
        <span class="cf-label__req" aria-hidden="true">*</span>
        <span class="cf-label__en">MESSAGE</span>
      </label>
      <textarea
        class="cf-textarea"
        id="cf-message"
        name="message"
        rows="6"
        aria-required="true"
        aria-describedby="cf-message-error"
        placeholder="請描述您的晶圓廠建置需求、IT/OT現況、或希望我們評估的範圍…"
      ></textarea>
      <span
        id="cf-message-error"
        class="cf-error"
        data-error="message"
        aria-live="polite"
      ></span>
    </div>

    <!-- ── Honeypot (hidden from real users) ─────────────────── -->
    <div class="cf-field cf-field--honey" aria-hidden="true">
      <label for="cf-website">Website</label>
      <input
        id="cf-website"
        name="website"
        type="text"
        tabindex="-1"
        autocomplete="off"
      />
    </div>

    <!-- ── Status (aria-live announcement region) ────────────── -->
    <div
      class="cf-status"
      data-form-status
      data-status=""
      role="status"
      aria-live="polite"
      aria-atomic="true"
    ></div>

    <!-- ── Data notice ───────────────────────────────────────── -->
    <p class="cf-notice">
      送出後，您的諮詢內容會傳送並保存至本公司的 Google 工作表，僅用於回覆此次諮詢。
    </p>

    <!-- ── Submit ────────────────────────────────────────────── -->
    <button class="cf-submit" type="submit">送出諮詢 →</button>
  </form>
</div>

<script>
  import { initContactForm } from '../scripts/contact-form';

  const formEl = document.getElementById('contact-form') as HTMLFormElement | null;
  if (formEl) initContactForm(formEl);
</script>

<style>
  /* ── Wrapper ─────────────────────────────────────────────────── */
  .cf-wrap {
    background: var(--surface);
    border: 1px solid var(--border-strong);
    padding: clamp(1.75rem, 5vw, 3rem);
    /* Restrained elevation — Direction C */
    box-shadow:
      0 2px 8px rgba(0, 0, 0, 0.3),
      0 8px 32px rgba(0, 0, 0, 0.2);
    position: relative;
    /* Left clay accent hairline */
    border-left: 2px solid var(--clay);
  }

  /* ── HUD decoration ──────────────────────────────────────────── */
  .cf-hud {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1.75rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    color: var(--ink-faint);
  }
  .cf-hud__sep {
    opacity: 0.5;
  }
  .cf-hud__label {
    color: var(--sun);
  }

  /* ── Form ─────────────────────────────────────────────────────── */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Side-by-side row on wider viewports */
  .cf-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) {
    .cf-row {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* ── Field ───────────────────────────────────────────────────── */
  .cf-field {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  /* Honeypot: visually hidden from real users, accessible to nothing */
  .cf-field--honey {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Label ───────────────────────────────────────────────────── */
  .cf-label {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    flex-wrap: wrap;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--ink); /* Never --ink-muted for labels per DESIGN.md */
    line-height: 1.2;
  }
  .cf-label__req {
    color: var(--clay);
    font-size: 0.95em;
  }
  .cf-label__opt {
    font-size: 0.78em;
    font-weight: 400;
    color: var(--ink-faint);
  }
  .cf-label__en {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    color: var(--ink-faint);
    margin-left: auto; /* push to trailing edge */
  }

  /* ── Shared control base ─────────────────────────────────────── */
  .cf-input,
  .cf-select,
  .cf-textarea {
    width: 100%;
    background: var(--bg-deep);
    color: var(--ink);
    border: 1px solid var(--border-strong);
    border-radius: 2px;
    padding: 0.75rem 1rem;
    font-family: inherit;
    font-size: 0.95rem;
    line-height: 1.5;
    transition:
      border-color var(--dur-quick) var(--ease-out),
      box-shadow var(--dur-quick) var(--ease-out);
    -webkit-appearance: none;
    appearance: none;
  }

  /* Placeholder */
  .cf-input::placeholder,
  .cf-textarea::placeholder {
    color: var(--ink-faint);
    opacity: 1;
  }

  /* Focus-visible: sun ring */
  .cf-input:focus-visible,
  .cf-select:focus-visible,
  .cf-textarea:focus-visible {
    outline: 2px solid var(--sun);
    outline-offset: 3px;
    border-color: var(--sun);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--sun) 20%, transparent);
  }

  /* Invalid state */
  .cf-input[aria-invalid='true'],
  .cf-select[aria-invalid='true'],
  .cf-textarea[aria-invalid='true'] {
    border-color: var(--clay);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--clay) 25%, transparent);
  }

  /* Textarea */
  .cf-textarea {
    resize: vertical;
    min-height: 9rem;
  }

  /* ── Select wrapper (custom arrow) ───────────────────────────── */
  .cf-select-wrap {
    position: relative;
  }
  .cf-select {
    padding-right: 2.5rem;
    cursor: pointer;
  }
  .cf-select-arrow {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.9rem;
    color: var(--sun);
    pointer-events: none;
    line-height: 1;
  }
  /* Option theming (limited cross-browser but improves Chrome/Firefox) */
  .cf-select option {
    background: var(--surface);
    color: var(--ink);
  }

  /* ── Per-field error text ────────────────────────────────────── */
  .cf-error {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--clay);
    letter-spacing: 0.04em;
    min-height: 1.1em; /* reserve space so layout doesn't shift */
    line-height: 1.4;
  }
  .cf-error:empty {
    display: none;
  }

  /* ── Status (form-level announcement) ───────────────────────── */
  .cf-status {
    font-size: 0.9rem;
    line-height: 1.5;
    border-radius: 2px;
    padding: 0;
    transition: padding var(--dur-quick) var(--ease-out);
  }
  .cf-status:empty {
    display: none;
  }
  /* Success — sage (coverage / delivery confirmed) */
  .cf-status[data-status='success'] {
    color: var(--sage);
    border: 1px solid color-mix(in srgb, var(--sage) 35%, transparent);
    background: color-mix(in srgb, var(--sage) 8%, transparent);
    padding: 0.85rem 1.1rem;
    /* Sage label MUST accompany the color */
    position: relative;
  }
  .cf-status[data-status='success']::before {
    content: '[ 已送出 · SENT ]  ';
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    font-weight: 600;
    color: var(--sage);
    opacity: 0.75;
  }
  /* Error — clay (resilience / recovery signal) */
  .cf-status[data-status='error'] {
    color: var(--clay);
    border: 1px solid color-mix(in srgb, var(--clay) 35%, transparent);
    background: color-mix(in srgb, var(--clay) 8%, transparent);
    padding: 0.85rem 1.1rem;
    position: relative;
  }
  .cf-status[data-status='error']::before {
    content: '[ 錯誤 · ERROR ]  ';
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    font-weight: 600;
    color: var(--clay);
    opacity: 0.75;
  }

  /* ── Data notice ─────────────────────────────────────────────── */
  .cf-notice {
    font-size: 0.8rem;
    color: var(--ink-faint);
    line-height: 1.5;
    margin: 0;
  }

  /* ── Submit button ───────────────────────────────────────────── */
  .cf-submit {
    align-self: flex-start;
    background: var(--clay-deep);
    color: var(--bg); /* Dark ink on clay — WCAG requirement per DESIGN.md */
    border: none;
    border-radius: 2px;
    padding: 0.85rem 2.2rem;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition:
      background var(--dur-quick) var(--ease-out),
      box-shadow var(--dur-quick) var(--ease-out),
      transform var(--dur-instant) var(--ease-out);
  }
  .cf-submit:hover:not(:disabled) {
    background: var(--clay);
    box-shadow: 0 4px 16px color-mix(in srgb, var(--clay) 30%, transparent);
  }
  .cf-submit:active:not(:disabled) {
    transform: translateY(1px);
  }
  .cf-submit:focus-visible {
    outline: 2px solid var(--sun);
    outline-offset: 3px;
  }
  .cf-submit:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }
</style>
