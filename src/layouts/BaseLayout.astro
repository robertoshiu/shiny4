---
import '../styles/tokens.css';
import '../styles/fonts.css';
import '../styles/global.css';
import SkipLink from '../components/SkipLink.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Locale } from '../i18n/utils';
import { siblingUrl } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  locale?: Locale;
}
const { title, description, locale = 'zh-Hant' } = Astro.props;
const htmlLang = locale === 'zh-Hans' ? 'zh-Hans' : locale === 'en' ? 'en' : 'zh-Hant';
const pathname = Astro.url.pathname;
const canonical = new URL(pathname, Astro.site).href;
const ogImage = new URL('/og-image.png', Astro.site).href;

// Compute per-page hreflang siblings
const hrefZhHant = new URL(siblingUrl(pathname, 'zh-Hant'), Astro.site).href;
const hrefEn = new URL(siblingUrl(pathname, 'en'), Astro.site).href;
const hrefZhHans = new URL(siblingUrl(pathname, 'zh-Hans'), Astro.site).href;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <link rel="alternate" hreflang="zh-Hant" href={hrefZhHant} />
    <link rel="alternate" hreflang="en" href={hrefEn} />
    <link rel="alternate" hreflang="zh-Hans" href={hrefZhHans} />
    <link rel="alternate" hreflang="x-default" href={hrefZhHant} />
    <!-- Self-hosted latin fonts (Fraunces, Nunito Sans, Spline Sans Mono) resolve from
         /fonts/ via @font-face in fonts.css — no cross-origin stylesheet fetch needed.
         Preload the two fonts that are most likely to be the LCP element. -->
    <link rel="preload" as="font" type="font/woff2" href="/fonts/fraunces-latin.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/nunito-sans-latin.woff2" crossorigin />
    <!-- CJK fonts (Noto Serif TC / Noto Sans TC) loaded async — never blocks first paint.
         font-display:swap in the Google Fonts URL ensures fallback text shows immediately. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@500;700;900&family=Noto+Sans+TC:wght@400;500;700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@500;700;900&family=Noto+Sans+TC:wght@400;500;700&display=swap"
      />
    </noscript>
    <!-- Pre-paint: reduced-motion + lang-persist redirect (root only). -->
    <script is:inline>
      (function () {
        // Reduced-motion
        try {
          if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            document.documentElement.classList.add('reduced-motion');
          }
        } catch (e) {}

        // Lang-persist: on bare root '/' redirect to stored locale pref.
        try {
          var path = location.pathname;
          if (path !== '/') return; // only redirect on the unprefixed root

          function readPref() {
            var m = document.cookie.match(/(?:^|;\s*)pref_lang=([^;]+)/);
            if (m) return m[1];
            try { return localStorage.getItem('pref_lang'); } catch (e) { return null; }
          }

          // Honor ?lang= override: write pref and redirect.
          var params = new URLSearchParams(location.search);
          var langParam = params.get('lang');
          if (langParam) {
            var target = null;
            var exp = new Date(Date.now() + 365 * 24 * 60 * 60 * 1000).toUTCString();
            if (langParam === 'en') {
              document.cookie = 'pref_lang=en; expires=' + exp + '; path=/; SameSite=Lax';
              target = '/en/';
            } else if (langParam === 'zh-hans' || langParam === 'zh-Hans') {
              document.cookie = 'pref_lang=zh-Hans; expires=' + exp + '; path=/; SameSite=Lax';
              target = '/zh-hans/';
            }
            if (target) { location.replace(target); return; }
          }

          var pref = readPref();
          if (pref === 'en') { location.replace('/en/'); return; }
          if (pref === 'zh-Hans') { location.replace('/zh-hans/'); return; }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <SkipLink locale={locale} />
    <Header locale={locale} />
    <slot />
    <Footer locale={locale} />
    <script>
      import '../scripts/lang-persist';
    </script>
  </body>
</html>
